<%- include('partials/header', { titulo: 'Carta Porte' }) %>
<%- include('partials/sidebar') %>
<div id="page-content">
  <div class="d-flex align-items-center mb-3">
    <button class="btn btn-sm btn-outline-secondary me-3 d-md-none" id="sidebarToggle"><i class="bi bi-list fs-5"></i></button>
    <h4 class="mb-0 fw-bold flex-grow-1">Carta Porte</h4>
    <span class="badge bg-secondary ms-2">Serie: <strong><%= usuario.serie || '—' %></strong></span>
    <span class="badge bg-warning text-dark ms-1">Año: <strong><%= anio %></strong></span>
  </div>

  <!-- Search + Buttons -->
  <div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
      <div class="row align-items-center g-2">
        <div class="col-auto">
          <select id="searchCol" class="form-select form-select-sm">
            <option value="NombreComunCli">Cliente</option>
            <option value="CartaPorte">Carta Porte</option>
            <option value="DesFlete">Descripción flete</option>
            <option value="Status">Status</option>
            <option value="RealizoPedido">Realizó</option>
          </select>
        </div>
        <div class="col col-md-4">
          <input type="text" id="searchInput" class="form-control form-control-sm" placeholder="Buscar...">
        </div>
        <div class="col-auto ms-auto btn-action-group">
          <% if (anio === new Date().getFullYear()) { %>
          <button class="btn btn-sm btn-success" id="btnAgregar" onclick="openAdd()"><i class="bi bi-plus-lg"></i> Agregar</button>
          <button class="btn btn-sm btn-primary" id="btnEditar" data-requires-selection disabled onclick="openEdit()"><i class="bi bi-pencil"></i> Editar</button>
          <button class="btn btn-sm btn-danger" id="btnEliminar" data-requires-selection disabled onclick="confirmDelete()"><i class="bi bi-trash"></i> Eliminar</button>
          <% } %>
          <button class="btn btn-sm btn-outline-primary" data-requires-selection disabled onclick="openVisualizar()"><i class="bi bi-eye"></i> Visualizar</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Table -->
  <div class="card border-0 shadow-sm">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover table-sm mb-0">
          <thead class="thead-tlc">
            <tr>
              <th data-sort="Serie" style="width:70px">Serie <span class="sort-icon"></span></th>
              <th data-sort="CartaPorte" style="width:120px">Carta Porte <span class="sort-icon"></span></th>
              <th data-sort="FechaPedido" style="width:105px">F. Pedido <span class="sort-icon"></span></th>
              <th data-sort="FehcaCarga" style="width:105px">F. Carga <span class="sort-icon"></span></th>
              <th data-sort="NombreComunCli">Cliente <span class="sort-icon"></span></th>
              <th data-sort="DesFlete">Descripción flete <span class="sort-icon"></span></th>
              <th data-sort="Status" style="width:100px">Status <span class="sort-icon"></span></th>
              <th data-sort="RealizoPedido" style="width:110px">Realizó <span class="sort-icon"></span></th>
            </tr>
          </thead>
          <tbody id="tableBody"></tbody>
        </table>
      </div>
    </div>
    <div class="card-footer bg-white d-flex align-items-center justify-content-between py-2">
      <span class="page-info" id="pageInfo"></span>
      <div id="pagination">
        <button class="btn btn-sm btn-outline-secondary" data-action="prev"><i class="bi bi-chevron-left"></i> Anterior</button>
        <button class="btn btn-sm btn-outline-secondary" data-action="next">Siguiente <i class="bi bi-chevron-right"></i></button>
      </div>
    </div>
  </div>
</div>

<!-- ═══════════════════ MODAL PRINCIPAL ═══════════════════════════════════════ -->
<div class="modal fade" id="frmModal" tabindex="-1">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="frmTitle">Carta Porte</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div id="frmError" class="alert alert-danger d-none py-2 small"></div>
        <ul class="nav nav-tabs mb-3" id="cpTabs" role="tablist">
          <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#tabCP">Carta Porte</a></li>
          <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tabMerc" id="tabMercLink">Mercancías</a></li>
          <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tabDepo" id="tabDepoLink">Depósitos</a></li>
          <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tabCostos">Costos</a></li>
        </ul>
        <div class="tab-content">

          <!-- ── TAB 1: CARTA PORTE ─────────────────────────────────────── -->
          <div class="tab-pane fade show active" id="tabCP">
            <!-- Fila 1 -->
            <div class="row g-2 mb-2">
              <div class="col-md-2">
                <label class="form-label fw-semibold small mb-1">Serie</label>
                <input type="text" id="f_Serie" class="form-control form-control-sm" readonly>
              </div>
              <div class="col-md-3">
                <label class="form-label fw-semibold small mb-1">Carta Porte</label>
                <input type="text" id="f_CartaPorte" class="form-control form-control-sm" readonly>
              </div>
              <div class="col-md-3">
                <label class="form-label fw-semibold small mb-1">Fecha pedido</label>
                <input type="date" id="f_FechaPedido" class="form-control form-control-sm" readonly>
              </div>
              <div class="col-md-2">
                <label class="form-label fw-semibold small mb-1">Status</label>
                <input type="text" id="f_Status" class="form-control form-control-sm" maxlength="20">
              </div>
              <div class="col-md-2">
                <label class="form-label fw-semibold small mb-1">Realizó</label>
                <input type="text" id="f_RealizoPedido" class="form-control form-control-sm" readonly>
              </div>
            </div>
            <!-- Fila 2 -->
            <div class="row g-2 mb-2">
              <div class="col-md-2">
                <label class="form-label fw-semibold small mb-1">F. Carga <span class="text-danger">*</span></label>
                <input type="date" id="f_FehcaCarga" class="form-control form-control-sm">
              </div>
              <div class="col-md-2">
                <label class="form-label fw-semibold small mb-1">Hora carga</label>
                <input type="time" id="f_HoraCarga" class="form-control form-control-sm">
              </div>
              <div class="col-md-2">
                <label class="form-label fw-semibold small mb-1">F. Descarga <span class="text-danger">*</span></label>
                <input type="date" id="f_FechaDesCarta" class="form-control form-control-sm">
              </div>
              <div class="col-md-2">
                <label class="form-label fw-semibold small mb-1">Hora descarga</label>
                <input type="time" id="f_HorarioDesCarta" class="form-control form-control-sm">
              </div>
              <div class="col-md-2">
                <label class="form-label fw-semibold small mb-1">Booking</label>
                <input type="text" id="f_Booking" class="form-control form-control-sm" maxlength="20">
              </div>
              <div class="col-md-2">
                <label class="form-label fw-semibold small mb-1">No. Rainde</label>
                <input type="text" id="f_NoRainde" class="form-control form-control-sm" maxlength="20">
              </div>
            </div>
            <!-- Fila 3: Cliente -->
            <div class="row g-2 mb-2">
              <div class="col-md-8">
                <label class="form-label fw-semibold small mb-1">Cliente <span class="text-danger">*</span></label>
                <div class="input-group input-group-sm">
                  <input type="hidden" id="f_Id_Cliente">
                  <input type="text" id="f_NombreComunCli" class="form-control form-control-sm" readonly placeholder="Seleccionar...">
                  <button class="btn btn-outline-secondary" type="button" onclick="openLkCliente('principal')"><i class="bi bi-search"></i></button>
                  <button class="btn btn-outline-danger btn-sm" type="button" onclick="clearCliente()" title="Limpiar"><i class="bi bi-x"></i></button>
                </div>
              </div>
              <div class="col-md-4">
                <label class="form-label fw-semibold small mb-1">Contenedor</label>
                <input type="text" id="f_Contenedor" class="form-control form-control-sm" maxlength="20">
              </div>
            </div>
            <!-- Fila 4 -->
            <div class="row g-2 mb-2">
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-1">Cliente entrega</label>
                <div class="input-group input-group-sm">
                  <input type="hidden" id="f_Id_ClienteEnt">
                  <input type="text" id="f_ClienteEnt" class="form-control form-control-sm" readonly placeholder="Seleccionar...">
                  <button class="btn btn-outline-secondary" type="button" onclick="openLkCliente('ent')"><i class="bi bi-search"></i></button>
                </div>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-1">Cliente carga</label>
                <div class="input-group input-group-sm">
                  <input type="hidden" id="f_Id_ClienteCarga">
                  <input type="text" id="f_ClienteCarga" class="form-control form-control-sm" readonly placeholder="Seleccionar...">
                  <button class="btn btn-outline-secondary" type="button" onclick="openLkCliente('carga')"><i class="bi bi-search"></i></button>
                </div>
              </div>
            </div>
            <!-- Lookups dependientes del cliente -->
            <div id="seccionDependienteCliente" style="display:none">
              <!-- Fila 5: Tarifa -->
              <div class="row g-2 mb-2">
                <div class="col-md-8">
                  <label class="form-label fw-semibold small mb-1">Tarifa / Descripción flete <span class="text-danger">*</span></label>
                  <div class="input-group input-group-sm">
                    <input type="hidden" id="f_Id_Tarifa">
                    <input type="text" id="f_DesFlete" class="form-control form-control-sm" readonly placeholder="Seleccionar tarifa...">
                    <button class="btn btn-outline-secondary" type="button" onclick="openLkTarifa()"><i class="bi bi-search"></i></button>
                  </div>
                </div>
              </div>
              <!-- Fila 6: Camion + Operador -->
              <div class="row g-2 mb-2">
                <div class="col-md-4">
                  <label class="form-label fw-semibold small mb-1">Camión <span class="text-danger">*</span></label>
                  <div class="input-group input-group-sm">
                    <input type="hidden" id="f_Id_Camion">
                    <input type="text" id="f_NoCamion" class="form-control form-control-sm" readonly placeholder="Seleccionar...">
                    <button class="btn btn-outline-secondary" type="button" onclick="openLkCamion()"><i class="bi bi-search"></i></button>
                  </div>
                </div>
                <div class="col-md-2">
                  <label class="form-label fw-semibold small mb-1">Placas</label>
                  <input type="text" id="f_NoPlacas" class="form-control form-control-sm" readonly>
                </div>
                <div class="col-md-3">
                  <label class="form-label fw-semibold small mb-1">Caja 1 <span class="text-danger">*</span></label>
                  <div class="input-group input-group-sm">
                    <input type="text" id="f_NoCaja" class="form-control form-control-sm" readonly placeholder="Seleccionar...">
                    <button class="btn btn-outline-secondary" type="button" onclick="openLkRemolque('caja1')"><i class="bi bi-search"></i></button>
                  </div>
                </div>
                <div class="col-md-3">
                  <label class="form-label fw-semibold small mb-1">Caja 2</label>
                  <div class="input-group input-group-sm">
                    <input type="text" id="f_NoCaja2" class="form-control form-control-sm" readonly placeholder="Seleccionar...">
                    <button class="btn btn-outline-secondary" type="button" onclick="openLkRemolque('caja2')"><i class="bi bi-search"></i></button>
                  </div>
                </div>
              </div>
              <!-- Fila 7: Operador -->
              <div class="row g-2 mb-2">
                <div class="col-md-6">
                  <label class="form-label fw-semibold small mb-1">Operador <span class="text-danger">*</span></label>
                  <div class="input-group input-group-sm">
                    <input type="hidden" id="f_Id_Operador">
                    <input type="text" id="f_Operador" class="form-control form-control-sm" readonly placeholder="Seleccionar...">
                    <button class="btn btn-outline-secondary" type="button" onclick="openLkOperador()"><i class="bi bi-search"></i></button>
                  </div>
                </div>
              </div>
              <!-- Fila 8: Domicilios -->
              <div class="row g-2 mb-2">
                <div class="col-md-6">
                  <label class="form-label fw-semibold small mb-1">Dom. carga <span class="text-danger">*</span></label>
                  <div class="input-group input-group-sm">
                    <input type="hidden" id="f_Id_DomCarga">
                    <input type="text" id="f_DomCarga" class="form-control form-control-sm" readonly placeholder="Seleccionar...">
                    <button class="btn btn-outline-secondary" type="button" onclick="openLkDom('carga')"><i class="bi bi-search"></i></button>
                  </div>
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-semibold small mb-1">Dom. descarga <span class="text-danger">*</span></label>
                  <div class="input-group input-group-sm">
                    <input type="hidden" id="f_Id_DomDescarga1">
                    <input type="text" id="f_DomDescarga" class="form-control form-control-sm" readonly placeholder="Seleccionar...">
                    <button class="btn btn-outline-secondary" type="button" onclick="openLkDom('descarga')"><i class="bi bi-search"></i></button>
                  </div>
                </div>
              </div>
            </div><!-- /seccionDependienteCliente -->

            <!-- Observaciones -->
            <div class="row g-2 mb-2">
              <div class="col-12">
                <label class="form-label fw-semibold small mb-1">Observaciones</label>
                <textarea id="f_Observaciones" class="form-control form-control-sm" rows="2" maxlength="255"></textarea>
              </div>
            </div>
          </div><!-- /tabCP -->

          <!-- ── TAB 2: MERCANCÍAS ──────────────────────────────────────── -->
          <div class="tab-pane fade" id="tabMerc">
            <div class="d-flex justify-content-end mb-2">
              <button class="btn btn-sm btn-success" onclick="openAddMerc()"><i class="bi bi-plus-lg"></i> Agregar mercancía</button>
            </div>
            <div class="table-responsive">
              <table class="table table-hover table-sm mb-0">
                <thead class="thead-tlc">
                  <tr>
                    <th style="width:50px">#</th>
                    <th>SKU</th>
                    <th>Descripción</th>
                    <th style="width:80px">Cantidad</th>
                    <th style="width:90px">Clave Unidad</th>
                    <th style="width:90px">Peso (kg)</th>
                    <th style="width:110px">Valor</th>
                    <th style="width:60px"></th>
                  </tr>
                </thead>
                <tbody id="mercBody"></tbody>
              </table>
            </div>
          </div><!-- /tabMerc -->

          <!-- ── TAB 3: DEPÓSITOS ───────────────────────────────────────── -->
          <div class="tab-pane fade" id="tabDepo">
            <div class="d-flex justify-content-end mb-2">
              <button class="btn btn-sm btn-success" onclick="openAddDepo()"><i class="bi bi-plus-lg"></i> Agregar depósito</button>
            </div>
            <div class="table-responsive">
              <table class="table table-hover table-sm mb-0">
                <thead class="thead-tlc">
                  <tr>
                    <th style="width:70px">ID</th>
                    <th style="width:100px">Fecha</th>
                    <th>Operador</th>
                    <th>Origen</th>
                    <th>Destino</th>
                    <th style="width:90px">Monto</th>
                    <th style="width:80px">Autorizado</th>
                    <th style="width:60px"></th>
                  </tr>
                </thead>
                <tbody id="depoBody"></tbody>
              </table>
            </div>
          </div><!-- /tabDepo -->

          <!-- ── TAB 4: COSTOS ──────────────────────────────────────────── -->
          <div class="tab-pane fade" id="tabCostos">
            <div class="row g-2">
              <div class="col-12"><h6 class="text-primary fw-bold border-bottom pb-1 mb-2">Costos de venta</h6></div>
              <div class="col-md-2"><label class="form-label fw-semibold small mb-1">Flete</label><input type="number" id="f_CostoFlete" class="form-control form-control-sm" step="0.01"></div>
              <div class="col-md-2"><label class="form-label fw-semibold small mb-1">Maniobras</label><input type="number" id="f_CostoManiobras" class="form-control form-control-sm" step="0.01"></div>
              <div class="col-md-2"><label class="form-label fw-semibold small mb-1">Demoras</label><input type="number" id="f_CostoDemoras" class="form-control form-control-sm" step="0.01"></div>
              <div class="col-md-2"><label class="form-label fw-semibold small mb-1">Autopistas</label><input type="number" id="f_CostoAutopistas" class="form-control form-control-sm" step="0.01"></div>
              <div class="col-md-2"><label class="form-label fw-semibold small mb-1">Dob. operador</label><input type="number" id="f_CostoDobOpe" class="form-control form-control-sm" step="0.01"></div>
              <div class="col-md-2"><label class="form-label fw-semibold small mb-1">Diesel venta</label><input type="number" id="f_CostoDisel" class="form-control form-control-sm" step="0.01"></div>
              <div class="col-md-2"><label class="form-label fw-semibold small mb-1">No. paradas</label><input type="number" id="f_NoParadas" class="form-control form-control-sm"></div>
              <div class="col-md-2"><label class="form-label fw-semibold small mb-1">Costo parada</label><input type="number" id="f_CostoParada" class="form-control form-control-sm" step="0.01"></div>
              <div class="col-md-2"><label class="form-label fw-semibold small mb-1">Otros costos</label><input type="number" id="f_CostosOtros" class="form-control form-control-sm" step="0.01"></div>
              <div class="col-md-4"><label class="form-label fw-semibold small mb-1">Desc. otros costos</label><input type="text" id="f_DesOtrosCostos" class="form-control form-control-sm" maxlength="255"></div>
              <div class="col-md-2"><label class="form-label fw-semibold small mb-1">Cargo extra trans</label><input type="number" id="f_CargoExtraTrans" class="form-control form-control-sm" step="0.01"></div>
              <div class="col-md-2"><label class="form-label fw-semibold small mb-1">Kilómetros</label><input type="number" id="f_Kilometros" class="form-control form-control-sm" step="0.01"></div>
              <div class="col-md-2"><label class="form-label fw-semibold small mb-1">Km tarifa</label><input type="number" id="f_KilometrosTar" class="form-control form-control-sm"></div>
              <div class="col-md-2"><label class="form-label fw-semibold small mb-1">Retención/km</label><input type="number" id="f_RetenKilo" class="form-control form-control-sm" step="0.01"></div>
              <div class="col-md-2"><label class="form-label fw-semibold small mb-1">Moneda</label><input type="text" id="f_c_Moneda" class="form-control form-control-sm" maxlength="10"></div>
              <div class="col-md-2"><label class="form-label fw-semibold small mb-1">Tipo cambio</label><input type="number" id="f_TipoCambio" class="form-control form-control-sm" step="0.01"></div>

              <div class="col-12"><h6 class="text-primary fw-bold border-bottom pb-1 mb-2 mt-2">Flags de cobro</h6></div>
              <div class="col-md-2"><div class="form-check"><input class="form-check-input" type="checkbox" id="f_FlagCobMan"><label class="form-check-label small">Cob. maniobras</label></div></div>
              <div class="col-md-2"><div class="form-check"><input class="form-check-input" type="checkbox" id="f_FlagCobDem"><label class="form-check-label small">Cob. demoras</label></div></div>
              <div class="col-md-2"><div class="form-check"><input class="form-check-input" type="checkbox" id="f_FlagCobAuto"><label class="form-check-label small">Cob. autopistas</label></div></div>
              <div class="col-md-2"><div class="form-check"><input class="form-check-input" type="checkbox" id="f_FlagCobDO"><label class="form-check-label small">Cob. dob. oper.</label></div></div>
              <div class="col-md-2"><div class="form-check"><input class="form-check-input" type="checkbox" id="f_FlagConDis"><label class="form-check-label small">Con diesel</label></div></div>
              <div class="col-md-2"><div class="form-check"><input class="form-check-input" type="checkbox" id="f_FlagCobParada"><label class="form-check-label small">Cob. parada</label></div></div>
              <div class="col-md-2"><div class="form-check"><input class="form-check-input" type="checkbox" id="f_FlagCobOtros"><label class="form-check-label small">Cob. otros</label></div></div>
              <div class="col-md-2"><div class="form-check"><input class="form-check-input" type="checkbox" id="f_FlagCobCE"><label class="form-check-label small">Cob. cargo extra</label></div></div>
              <div class="col-md-2"><div class="form-check"><input class="form-check-input" type="checkbox" id="f_FlagIVA"><label class="form-check-label small">IVA</label></div></div>
              <div class="col-md-2"><div class="form-check"><input class="form-check-input" type="checkbox" id="f_FlagRet"><label class="form-check-label small">Retención</label></div></div>

              <div class="col-12"><h6 class="text-primary fw-bold border-bottom pb-1 mb-2 mt-2">Totales MXN</h6></div>
              <div class="col-md-2"><label class="form-label fw-semibold small mb-1">% IVA</label><input type="number" id="f_PorIVAMX" class="form-control form-control-sm" value="16"></div>
              <div class="col-md-2"><label class="form-label fw-semibold small mb-1">SubTotal MX</label><input type="number" id="f_SubTotalMX" class="form-control form-control-sm bg-light" readonly></div>
              <div class="col-md-2"><label class="form-label fw-semibold small mb-1">IVA MX</label><input type="number" id="f_IVAMX" class="form-control form-control-sm bg-light" readonly></div>
              <div class="col-md-2"><label class="form-label fw-semibold small mb-1">Retención MX</label><input type="number" id="f_RetenMX" class="form-control form-control-sm bg-light" readonly></div>
              <div class="col-md-2"><label class="form-label fw-semibold small mb-1 text-primary">TOTAL MX</label><input type="number" id="f_TOTALMX" class="form-control form-control-sm fw-bold" readonly></div>
              <div class="col-md-2 d-flex align-items-end">
                <button class="btn btn-sm btn-outline-primary w-100" onclick="recalcular()"><i class="bi bi-calculator"></i> Recalcular</button>
              </div>

              <div class="col-12"><h6 class="text-primary fw-bold border-bottom pb-1 mb-2 mt-2">Costos operativos</h6></div>
              <div class="col-md-2"><label class="form-label fw-semibold small mb-1">Préstamo</label><input type="number" id="f_CostoPrestamo" class="form-control form-control-sm" step="0.01"></div>
              <div class="col-md-2"><label class="form-label fw-semibold small mb-1">Talacha</label><input type="number" id="f_CostoTalacha" class="form-control form-control-sm" step="0.01"></div>
