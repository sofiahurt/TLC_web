    .then(r => r.json())
    .then(rows => {
      const body = document.getElementById('mercBody');
      body.innerHTML = rows.map(r =>
        `<tr>
          <td>${r.Id_Mercancia}</td>
          <td>${r.SKU||''}</td>
          <td>${r.Descripcion||''}</td>
          <td>${r.Cantidad||''}</td>
          <td>${r.ClaveUnidad||''}</td>
          <td>${r.PesoEnKg||''}</td>
          <td>${r.ValorMercancia||''}</td>
