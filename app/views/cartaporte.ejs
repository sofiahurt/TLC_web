// ── LOOKUP GENÉRICO ───────────────────────────────────────────────────────────
let _lkUrl = '', _lkPage = 1, _lkOnSelect = null, _lkDebounce = null;
let _lkExtraParams = {};

function openGenericLookup(title, headers, url, extraParams, onSelect) {
  _lkUrl = url; _lkPage = 1; _lkOnSelect = onSelect; _lkExtraParams = extraParams || {};
  document.getElementById('lkTitle').textContent = title;
  document.getElementById('lkSearch').value = '';
  const thead = document.getElementById('lkThead').querySelector('tr');
  thead.innerHTML = headers.map(h => `<th>${h}</th>`).join('');
  lkLoadPage();
  lkModal.show();
}

function lkLoadPage() {
  const q = document.getElementById('lkSearch').value;
  const extra = Object.entries(_lkExtraParams).map(([k,v]) => `&${k}=${encodeURIComponent(v)}`).join('');
  fetch(`${_lkUrl}?q=${encodeURIComponent(q)}&page=${_lkPage}${extra}`)
    .then(r => r.json())
    .then(d => {
      document.getElementById('lkBody').innerHTML = (d.rows || []).map(r =>
        `<tr style="cursor:pointer" onclick="lkSelect(this)" data-row='${JSON.stringify(r)}'>
          ${Object.values(r).map(v => `<td>${v??''}</td>`).join('')}
        </tr>`
      ).join('') || '<tr><td colspan="10" class="text-center text-muted small">Sin resultados</td></tr>';
      document.getElementById('lkInfo').textContent = `Pág ${d.page} de ${d.totalPages} — ${d.total} reg.`;
      document.getElementById('lkPrev').disabled = d.page <= 1;
      document.getElementById('lkNext').disabled = d.page >= d.totalPages;
    });
}

document.getElementById('lkSearch').addEventListener('input', () => {
  clearTimeout(_lkDebounce);
  _lkDebounce = setTimeout(() => { _lkPage = 1; lkLoadPage(); }, 300);
});
document.getElementById('lkPrev').addEventListener('click', () => { if (_lkPage > 1) { _lkPage--; lkLoadPage(); } });
document.getElementById('lkNext').addEventListener('click', () => { _lkPage++; lkLoadPage(); });

function lkSelect(tr) {
  const row = JSON.parse(tr.dataset.row);
  lkModal.hide();
  if (_lkOnSelect) _lkOnSelect(row);
}

// ── LOOKUPS ESPECÍFICOS ───────────────────────────────────────────────────────
function openLkCliente(target) {
  openGenericLookup('Buscar cliente', ['ID','Nombre','RFC'],
    '/cartaporte/lookup/clientes', {}, row => {
      if (target === 'principal') {
        document.getElementById('f_Id_Cliente').value = row.ID_CLIENTE;
        document.getElementById('f_NombreComunCli').value = (row.NOMBRECOMUN||'').trim();
        _currentIdCliente = String(row.ID_CLIENTE);
        // limpiar domicilios al cambiar cliente
        ['f_Id_DomCarga','f_DomCarga','f_Id_DomDescarga1','f_DomDescarga'].forEach(id => {
          const el = document.getElementById(id); if (el) el.value = '';
        });
        toggleSeccionCliente();
      } else if (target === 'ent') {
        document.getElementById('f_Id_ClienteEnt').value = row.ID_CLIENTE;
        document.getElementById('f_ClienteEnt').value = (row.NOMBRECOMUN||'').trim();
      } else {
        document.getElementById('f_Id_ClienteCarga').value = row.ID_CLIENTE;
        document.getElementById('f_ClienteCarga').value = (row.NOMBRECOMUN||'').trim();
      }
    });
}

function openLkTarifa() {
  openGenericLookup('Buscar tarifa', ['ID','Descripción','Tipo','Venta'],
    '/cartaporte/lookup/tarifas', { idCliente: _currentIdCliente }, row => {
      const flete = (row.FLETE||'').trim().toLowerCase();
      const renta = parseFloat(row.RENTA) || 0;
      const cKm   = parseFloat(row.COSTOKILOMTS) || 0;
      const cAuto = parseFloat(row.COSTOAUTOPISTAS) || 0;
      const km    = parseFloat(row.KILOMETROS) || 0;

      let cFlete = 0, cDem = 0, kmTar = 0, kmVal = 0, autoVal = 0;
      let valid = false;

      if (flete === 'flete' && renta !== 0) {
        cFlete = renta; kmTar = km; kmVal = cKm; autoVal = cAuto; valid = true;
      } else if ((flete === 'renta' && renta !== 0) || cKm !== 0 || cAuto !== 0) {
        cDem = renta; kmTar = km; kmVal = cKm; autoVal = cAuto; valid = true;
      }

      if (!valid) { alert('La tarifa seleccionada no cuenta con costos configurados'); return; }

      document.getElementById('f_Id_Tarifa').value = row.ID_TARIFA;
      document.getElementById('f_DesFlete').value  = (row.DESFLETE||'').trim();
      document.getElementById('f_CostoFlete').value     = cFlete.toFixed(2);
      document.getElementById('f_CostoDemoras').value   = cDem.toFixed(2);
      document.getElementById('f_KilometrosTar').value  = kmTar;
      document.getElementById('f_Kilometros').value     = kmVal.toFixed(2);
      document.getElementById('f_CostoAutopistas').value= autoVal.toFixed(2);
      const retenK = (kmVal * 0.04).toFixed(2);
      document.getElementById('f_RetenKilo').value      = retenK;
      document.getElementById('f_c_Moneda').value       = (row.MONVENTA||'').trim();
      document.getElementById('f_TipoCambio').value     = row.TIPOCAMBIO||0;
      document.getElementById('f_FlagIVA').checked      = parseInt(row.FLAGIVA) === 1;
      document.getElementById('f_FlagRet').checked      = parseInt(row.FLAGRET) === 1;
      recalcular();
    });
}

function openLkCamion() {
  openGenericLookup('Buscar camión', ['ID Camión','Descripción','Placas'],
    '/cartaporte/lookup/camiones', {}, row => {
      document.getElementById('f_Id_Camion').value = row.ID_CAMION;
      document.getElementById('f_NoCamion').value  = (row.DESCRIPCION||'').trim();
