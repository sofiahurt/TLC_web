<%- include('partials/footer') %>
<script>
// ── ESTADO ────────────────────────────────────────────────────────────────────
let _mode = 'add';
let _readOnly = false;
let _currentSerie = '';
let _currentCP = '';
let _currentIdCliente = '';
let _mercMode = 'add';
let _mercEditId = null;
let _depoMode = 'add';
let _depoEditId = null;
const today = new Date().toISOString().slice(0, 10);

const modal     = new bootstrap.Modal(document.getElementById('frmModal'));
const mercModal = new bootstrap.Modal(document.getElementById('mercModal'));
const depoModal = new bootstrap.Modal(document.getElementById('depoModal'));
const lkModal   = new bootstrap.Modal(document.getElementById('lkModal'));

// ── BROWSE ────────────────────────────────────────────────────────────────────
const browse = initBrowse({
  searchInput:  document.getElementById('searchInput'),
  searchColumn: document.getElementById('searchCol'),
  tableBody:    document.getElementById('tableBody'),
  paginationEl: document.getElementById('pagination'),
  infoEl:       document.getElementById('pageInfo'),
  fetchUrl:     '/cartaporte/data'
});

// ── OPEN MODAL ────────────────────────────────────────────────────────────────
function openAdd() {
  _mode = 'add'; _readOnly = false;
  document.getElementById('frmTitle').textContent = 'Nueva Carta Porte';
  document.getElementById('btnGuardar').style.display = '';
  clearForm();
  document.getElementById('f_FechaPedido').value = today;
  modal.show();
}

function openEdit() {
  if (!window._selectedRow) return;
  _mode = 'edit'; _readOnly = false;
  document.getElementById('frmTitle').textContent = 'Editar Carta Porte';
  document.getElementById('btnGuardar').style.display = '';
  loadForm(window._selectedRow.CartaPorte, window._selectedRow.Serie, false);
  modal.show();
}

function openVisualizar() {
  if (!window._selectedRow) return;
  _mode = 'view'; _readOnly = true;
  document.getElementById('frmTitle').textContent = 'Visualizar Carta Porte';
  document.getElementById('btnGuardar').style.display = 'none';
  loadForm(window._selectedRow.CartaPorte, window._selectedRow.Serie, true);
  modal.show();
}

function loadForm(cp, serie, ro) {
  _currentCP = cp; _currentSerie = serie;
  fetch(`/cartaporte/get?serie=${encodeURIComponent(serie)}&cartaporte=${encodeURIComponent(cp)}`)
    .then(r => r.json())
    .then(d => {
      if (d.error) { alert(d.error); return; }
      populateForm(d);
      setReadOnly(ro);
      _currentIdCliente = String(d.Id_Cliente || '');
      toggleSeccionCliente();
    });
}

function populateForm(d) {
  const set = (id, val) => { const el = document.getElementById(id); if (el) el.value = val ?? ''; };
  const chk = (id, val) => { const el = document.getElementById(id); if (el) el.checked = !!parseInt(val); };
  set('f_Serie', d.Serie); set('f_CartaPorte', d.CartaPorte);
  set('f_FechaPedido', d.FechaPedido); set('f_FehcaCarga', d.FehcaCarga);
  set('f_HoraCarga', d.HoraCarga); set('f_FechaDesCarta', d.FechaDesCarta);
  set('f_HorarioDesCarta', d.HorarioDesCarta);
  document.getElementById('f_Id_Cliente').value = d.Id_Cliente;
  set('f_NombreComunCli', d.NombreComunCli);
  document.getElementById('f_Id_ClienteEnt').value = d.Id_ClienteEnt;
  set('f_ClienteEnt', d.ClienteEnt);
  document.getElementById('f_Id_ClienteCarga').value = d.Id_ClienteCarga;
  set('f_ClienteCarga', d.ClienteCarga);
  set('f_Booking', d.Booking); set('f_NoRainde', d.NoRainde);
  set('f_Contenedor', d.Contenedor);
  document.getElementById('f_Id_Tarifa').value = d.Id_Tarifa;
  set('f_DesFlete', d.DesFlete);
  document.getElementById('f_Id_Camion').value = d.Id_Camion;
  set('f_NoCamion', d.NoCamion); set('f_NoPlacas', d.NoPlacas);
  set('f_NoCaja', d.NoCaja); set('f_NoCaja2', d.NoCaja2);
  document.getElementById('f_Id_Operador').value = d.Id_Operador;
  set('f_Operador', d.Operador);
  document.getElementById('f_Id_DomCarga').value = d.Id_DomCarga;
  set('f_DomCarga', d.DomCarga);
  document.getElementById('f_Id_DomDescarga1').value = d.Id_DomDescarga1;
  set('f_DomDescarga', d.DomDescarga);
  set('f_Status', d.Status); set('f_RealizoPedido', d.RealizoPedido);
  set('f_Observaciones', d.Observaciones);
  // costos
  ['CostoFlete','CostoManiobras','CostoDemoras','CostoAutopistas','CostoDobOpe','CostoDisel',
   'NoParadas','CostoParada','CostosOtros','CargoExtraTrans','Kilometros','KilometrosTar',
   'RetenKilo','c_Moneda','TipoCambio','DesOtrosCostos',
   'PorIVAMX','SubTotalMX','IVAMX','RetenMX','TOTALMX',
   'CostoPrestamo','CostoTalacha','CostoCompllanta','CostoDiesel','CostoCasetas',
   'CostoComidas','CostoManiobrasExt','CostoBascula','CostoPension','CostoRefacciones','CostoOtros'
  ].forEach(k => set('f_' + k, d[k]));
  ['FlagCobMan','FlagCobDem','FlagCobAuto','FlagCobDO','FlagConDis','FlagCobParada',
   'FlagCobOtros','FlagCobCE','FlagIVA','FlagRet'
  ].forEach(k => chk('f_' + k, d[k]));
}

function clearForm() {
  document.querySelectorAll('#frmModal input:not([readonly]), #frmModal textarea, #frmModal select').forEach(el => {
    if (el.type === 'checkbox') el.checked = false;
    else el.value = '';
  });
  document.getElementById('f_PorIVAMX').value = 16;
  _currentIdCliente = '';
  _currentCP = '';
  _currentSerie = '';
  toggleSeccionCliente();
}

function setReadOnly(ro) {
  document.querySelectorAll('#frmModal input, #frmModal textarea, #frmModal select').forEach(el => {
    if (el.type !== 'hidden') { el.disabled = ro; el.readOnly = ro && el.tagName !== 'SELECT'; }
  });
  document.querySelectorAll('#frmModal button:not([data-bs-dismiss])').forEach(b => b.disabled = ro);
}

function toggleSeccionCliente() {
  document.getElementById('seccionDependienteCliente').style.display = _currentIdCliente ? '' : 'none';
}

function clearCliente() {
  document.getElementById('f_Id_Cliente').value = '';
  document.getElementById('f_NombreComunCli').value = '';
  ['f_Id_DomCarga','f_DomCarga','f_Id_DomDescarga1','f_DomDescarga'].forEach(id => {
    const el = document.getElementById(id); if (el) el.value = '';
  });
  _currentIdCliente = '';
  toggleSeccionCliente();
}

// ── GUARDAR ───────────────────────────────────────────────────────────────────
function guardar() {
  const errEl = document.getElementById('frmError');
  const req = f => document.getElementById(f)?.value?.trim() || '';
  const miss = [];
  if (!req('f_FehcaCarga'))    miss.push('Fecha Carga');
  if (!req('f_FechaDesCarta')) miss.push('Fecha Descarga');
  if (!req('f_Id_Cliente'))    miss.push('Cliente');
  if (!req('f_Id_Tarifa'))     miss.push('Tarifa');
  if (!req('f_Id_Camion'))     miss.push('Camión');
  if (!req('f_NoCaja'))        miss.push('Caja 1');
  if (!req('f_Id_Operador'))   miss.push('Operador');
  if (!req('f_Id_DomCarga'))   miss.push('Dom. Carga');
  if (!req('f_Id_DomDescarga1')) miss.push('Dom. Descarga');
  if (miss.length) { errEl.textContent = 'Campos requeridos: ' + miss.join(', '); errEl.classList.remove('d-none'); return; }
  errEl.classList.add('d-none');

  const v = id => document.getElementById(id)?.value ?? '';
  const chk = id => document.getElementById(id)?.checked ? 1 : 0;
  const payload = {
    _mode,
    Serie: v('f_Serie'), CartaPorte: v('f_CartaPorte'),
    FechaPedido: v('f_FechaPedido'),
    FehcaCarga: v('f_FehcaCarga'), HoraCarga: v('f_HoraCarga'),
    FechaDesCarta: v('f_FechaDesCarta'), HorarioDesCarta: v('f_HorarioDesCarta'),
    Id_Cliente: v('f_Id_Cliente'), NombreComunCli: v('f_NombreComunCli'),
    Id_ClienteEnt: v('f_Id_ClienteEnt'), ClienteEnt: v('f_ClienteEnt'),
    Id_ClienteCarga: v('f_Id_ClienteCarga'), ClienteCarga: v('f_ClienteCarga'),
    Booking: v('f_Booking'), NoRainde: v('f_NoRainde'), Contenedor: v('f_Contenedor'),
    Id_Tarifa: v('f_Id_Tarifa'), DesFlete: v('f_DesFlete'),
    Id_Camion: v('f_Id_Camion'), NoCamion: v('f_NoCamion'), NoPlacas: v('f_NoPlacas'),
    NoCaja: v('f_NoCaja'), NoCaja2: v('f_NoCaja2'),
    Id_Operador: v('f_Id_Operador'), Operador: v('f_Operador'),
    Id_DomCarga: v('f_Id_DomCarga'), DomCarga: v('f_DomCarga'),
    Id_DomDescarga1: v('f_Id_DomDescarga1'), DomDescarga: v('f_DomDescarga'),
    CostoFlete: v('f_CostoFlete'), CostoManiobras: v('f_CostoManiobras'),
    CostoDemoras: v('f_CostoDemoras'), CostoAutopistas: v('f_CostoAutopistas'),
    CostoDobOpe: v('f_CostoDobOpe'), CostoDisel: v('f_CostoDisel'),
    NoParadas: v('f_NoParadas'), CostoParada: v('f_CostoParada'),
    CostosOtros: v('f_CostosOtros'), DesOtrosCostos: v('f_DesOtrosCostos'),
    CargoExtraTrans: v('f_CargoExtraTrans'), Kilometros: v('f_Kilometros'),
    KilometrosTar: v('f_KilometrosTar'), RetenKilo: v('f_RetenKilo'),
    c_Moneda: v('f_c_Moneda'), TipoCambio: v('f_TipoCambio'),
    FlagCobMan: chk('f_FlagCobMan'), FlagCobDem: chk('f_FlagCobDem'),
    FlagCobAuto: chk('f_FlagCobAuto'), FlagCobDO: chk('f_FlagCobDO'),
    FlagConDis: chk('f_FlagConDis'), FlagCobParada: chk('f_FlagCobParada'),
    FlagCobOtros: chk('f_FlagCobOtros'), FlagCobCE: chk('f_FlagCobCE'),
    FlagIVA: chk('f_FlagIVA'), FlagRet: chk('f_FlagRet'),
    SubTotalMX: v('f_SubTotalMX'), PorIVAMX: v('f_PorIVAMX'),
    IVAMX: v('f_IVAMX'), RetenMX: v('f_RetenMX'), TOTALMX: v('f_TOTALMX'),
    SubTotalUSD: 0, PorIVAUSD: 16, IVAUSD: 0, RetenUSD: 0, TOTALUSD: 0,
    CostoPrestamo: v('f_CostoPrestamo'), CostoTalacha: v('f_CostoTalacha'),
    CostoCompllanta: v('f_CostoCompllanta'), CostoDiesel: v('f_CostoDiesel'),
    CostoCasetas: v('f_CostoCasetas'), CostoComidas: v('f_CostoComidas'),
    CostoManiobrasExt: v('f_CostoManiobrasExt'), CostoBascula: v('f_CostoBascula'),
    CostoPension: v('f_CostoPension'), CostoRefacciones: v('f_CostoRefacciones'),
    CostoOtros: v('f_CostoOtros'),
    Status: v('f_Status'), Observaciones: v('f_Observaciones'), Booking: v('f_Booking')
  };

  fetch('/cartaporte/guardar', {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(payload)
  }).then(r => r.json()).then(d => {
    if (d.error) { errEl.textContent = d.error; errEl.classList.remove('d-none'); return; }
    modal.hide(); browse.load();
  });
}

function confirmDelete() {
  if (!window._selectedRow) return;
  if (!confirm(`¿Eliminar la carta porte "${window._selectedRow.CartaPorte}"?`)) return;
  fetch('/cartaporte/eliminar', {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ Serie: window._selectedRow.Serie, CartaPorte: window._selectedRow.CartaPorte })
  }).then(r => r.json()).then(d => { if (!d.error) browse.load(); });
}

// ── RECALCULAR ────────────────────────────────────────────────────────────────
function recalcular() {
  const n = id => parseFloat(document.getElementById(id)?.value) || 0;
  const chk = id => document.getElementById(id)?.checked ? 1 : 0;
  const sub = n('f_CostoFlete') + n('f_CostoManiobras') + n('f_CostoDemoras') +
              n('f_CostoAutopistas') + n('f_CostoDobOpe') + n('f_CostoDisel') +
              n('f_CostoParada') * n('f_NoParadas') + n('f_CostosOtros') +
              n('f_CargoExtraTrans') - n('f_RetenKilo');
  const porIVA = n('f_PorIVAMX') || 16;
  const iva    = chk('f_FlagIVA') ? sub * (porIVA / 100) : 0;
  const reten  = chk('f_FlagRet') ? sub * 0.04 : 0;
  const tot    = sub + iva - reten;
  document.getElementById('f_SubTotalMX').value = sub.toFixed(2);
  document.getElementById('f_IVAMX').value      = iva.toFixed(2);
  document.getElementById('f_RetenMX').value     = reten.toFixed(2);
  document.getElementById('f_TOTALMX').value     = tot.toFixed(2);
}

