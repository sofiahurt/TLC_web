<%- include('partials/header', { titulo: 'Precios Diesel' }) %>
<%- include('partials/sidebar') %>
<div id="page-content">
  <div class="d-flex align-items-center mb-3">
    <button class="btn btn-sm btn-outline-secondary me-3 d-md-none" id="sidebarToggle"><i class="bi bi-list fs-5"></i></button>
    <h4 class="mb-0 fw-bold flex-grow-1">Precios Diesel</h4>
  </div>
  <div class="card border-0 shadow-sm mb-3"><div class="card-body py-2">
    <div class="row align-items-center g-2">
      <div class="col-auto"><select id="searchCol" class="form-select form-select-sm"><option value="FECHA">Fecha</option><option value="ID_DIESELPRECIO">ID</option></select></div>
      <div class="col col-md-4"><input type="text" id="searchInput" class="form-control form-select-sm" placeholder="Buscar..."></div>
      <div class="col-auto ms-auto btn-action-group">
        <button class="btn btn-sm btn-success" onclick="openAdd()"><i class="bi bi-plus-lg"></i> Agregar</button>
        <button class="btn btn-sm btn-primary" data-requires-selection disabled onclick="openEdit()"><i class="bi bi-pencil"></i> Editar</button>
        <button class="btn btn-sm btn-danger" data-requires-selection disabled onclick="confirmDelete()"><i class="bi bi-trash"></i> Eliminar</button>
      </div>
    </div>
  </div></div>
  <div class="card border-0 shadow-sm"><div class="card-body p-0">
    <div class="table-responsive"><table class="table table-hover table-sm mb-0">
      <thead class="table-dark"><tr>
        <th data-sort="ID_DIESELPRECIO" style="width:100px">ID <span class="sort-icon"></span></th>
        <th data-sort="FECHA" style="width:130px">Fecha <span class="sort-icon"></span></th>
        <th data-sort="PRECIOLITRO">Precio/Litro <span class="sort-icon"></span></th>
        <th data-sort="IEPS">IEPS <span class="sort-icon"></span></th>
      </tr></thead>
      <tbody id="tableBody"></tbody>
    </table></div>
  </div>
  <div class="card-footer bg-white d-flex align-items-center justify-content-between py-2">
    <span class="page-info" id="pageInfo"></span>
    <div id="pagination">
      <button class="btn btn-sm btn-outline-secondary" data-action="prev"><i class="bi bi-chevron-left"></i> Anterior</button>
      <button class="btn btn-sm btn-outline-secondary" data-action="next">Siguiente <i class="bi bi-chevron-right"></i></button>
    </div>
  </div></div>
</div>
<div class="modal fade" id="frmModal" tabindex="-1"><div class="modal-dialog modal-dialog-centered">
  <div class="modal-content">
    <div class="modal-header"><h5 class="modal-title" id="frmTitle">Precio Diesel</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
    <div class="modal-body">
      <div id="frmError" class="alert alert-danger d-none py-2 small"></div>
      <div class="row g-3">
        <div class="col-4"><label class="form-label fw-semibold">ID <span class="text-danger">*</span></label><input type="number" id="f_ID" class="form-control"></div>
        <div class="col-4"><label class="form-label fw-semibold">Fecha</label><input type="date" id="f_FECHA" class="form-control"></div>
        <div class="col-4"><label class="form-label fw-semibold">Precio/Litro</label><input type="number" id="f_PRECIO" class="form-control" step="0.01"></div>
        <div class="col-4"><label class="form-label fw-semibold">IEPS</label><input type="number" id="f_IEPS" class="form-control" step="0.0001"></div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i> Cancelar</button>
      <button class="btn btn-primary" onclick="guardar()"><i class="bi bi-floppy"></i> Guardar</button>
    </div>
  </div>
</div></div>
<%- include('partials/footer') %>
<script>
const browse=initBrowse({searchInput:document.getElementById('searchInput'),searchColumn:document.getElementById('searchCol'),tableBody:document.getElementById('tableBody'),paginationEl:document.getElementById('pagination'),infoEl:document.getElementById('pageInfo'),fetchUrl:'/dieselpre/data'});
let _mode='add';const modal=new bootstrap.Modal(document.getElementById('frmModal'));
function openAdd(){_mode='add';document.getElementById('frmTitle').textContent='Nuevo Precio Diesel';['f_ID','f_FECHA','f_PRECIO','f_IEPS'].forEach(i=>document.getElementById(i).value='');document.getElementById('f_ID').readOnly=false;document.getElementById('frmError').classList.add('d-none');modal.show();}
function openEdit(){if(!window._selectedRow)return;_mode='edit';document.getElementById('frmTitle').textContent='Editar Precio Diesel';document.getElementById('f_ID').value=window._selectedRow.ID_DIESELPRECIO;document.getElementById('f_FECHA').value=window._selectedRow.FECHA;document.getElementById('f_PRECIO').value=window._selectedRow.PRECIOLITRO;document.getElementById('f_IEPS').value=window._selectedRow.IEPS;document.getElementById('f_ID').readOnly=true;document.getElementById('frmError').classList.add('d-none');modal.show();}
function guardar(){const id=document.getElementById('f_ID').value.trim(),errEl=document.getElementById('frmError');if(!id){errEl.textContent='ID es requerido.';errEl.classList.remove('d-none');return;}fetch('/dieselpre/guardar',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({ID_DIESELPRECIO:id,FECHA:document.getElementById('f_FECHA').value,PRECIOLITRO:document.getElementById('f_PRECIO').value,IEPS:document.getElementById('f_IEPS').value,_mode})}).then(r=>r.json()).then(d=>{if(d.error){errEl.textContent=d.error;errEl.classList.remove('d-none');return;}modal.hide();browse.load();});}
function confirmDelete(){if(!window._selectedRow)return;if(!confirm('¿Eliminar este registro?'))return;fetch('/dieselpre/eliminar',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({ID_DIESELPRECIO:window._selectedRow.ID_DIESELPRECIO})}).then(r=>r.json()).then(d=>{if(!d.error)browse.load();});}
</script>
