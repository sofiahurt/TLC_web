<nav id="sidebar" class="sidebar d-flex flex-column flex-shrink-0 p-0">
  <div class="sidebar-header p-3">
    <div class="fw-bold text-white fs-5">TLC Web</div>
    <div class="text-white-50 small mt-1">
      <i class="bi bi-person-circle me-1"></i>
      <%= usuario.nombre.trim() %> <%= usuario.apellido ? usuario.apellido.trim() : '' %>
    </div>
    <div class="d-flex gap-2 mt-1 flex-wrap">
      <% if (typeof serie !== 'undefined' && serie) { %>
        <span class="badge bg-primary" style="font-size:.7rem">Serie: <%= serie %></span>
      <% } %>
      <% if (typeof anio !== 'undefined' && anio) { %>
        <span class="badge" style="background:#E8861A;font-size:.7rem">Año: <%= anio %></span>
      <% } %>
    </div>
  </div>

  <div class="sidebar-menu flex-grow-1 overflow-auto px-2 py-1">

    <div class="sidebar-group" data-group="catalogos">
      <div class="sidebar-section sidebar-toggle">
        <span>Catálogos</span>
        <i class="bi bi-chevron-down sidebar-chevron"></i>
      </div>
      <div class="sidebar-group-body">
        <a href="/ciudades"   class="sidebar-link <%= modulo==='ciudades'  ?'active':'' %>"><i class="bi bi-geo-alt"></i> Ciudades</a>
        <a href="/colonias"   class="sidebar-link <%= modulo==='colonias'  ?'active':'' %>"><i class="bi bi-mailbox"></i> Colonias</a>
        <a href="/tipoflete"  class="sidebar-link <%= modulo==='tipoflete' ?'active':'' %>"><i class="bi bi-tags"></i> Tipos de Flete</a>
        <a href="/operadores" class="sidebar-link <%= modulo==='operadores'?'active':'' %>"><i class="bi bi-person-badge"></i> Operadores</a>
        <a href="/prodserv"   class="sidebar-link <%= modulo==='prodserv'  ?'active':'' %>"><i class="bi bi-box-seam"></i> Productos y Servicios</a>
      </div>
    </div>

    <div class="sidebar-group" data-group="clientes">
      <div class="sidebar-section sidebar-toggle">
        <span>Clientes y Transportistas</span>
        <i class="bi bi-chevron-down sidebar-chevron"></i>
      </div>
      <div class="sidebar-group-body">
        <a href="/clientes"   class="sidebar-link <%= modulo==='clientes'  ?'active':'' %>"><i class="bi bi-building"></i> Clientes</a>
        <a href="/contacto"   class="sidebar-link <%= modulo==='contacto'  ?'active':'' %>"><i class="bi bi-person-lines-fill"></i> Contactos</a>
        <a href="/domicilios" class="sidebar-link <%= modulo==='domicilios'?'active':'' %>"><i class="bi bi-house"></i> Domicilios</a>
        <a href="/transport"  class="sidebar-link <%= modulo==='transport' ?'active':'' %>"><i class="bi bi-truck"></i> Transportistas</a>
      </div>
    </div>

    <div class="sidebar-group" data-group="flota">
      <div class="sidebar-section sidebar-toggle">
        <span>Flota</span>
        <i class="bi bi-chevron-down sidebar-chevron"></i>
      </div>
      <div class="sidebar-group-body">
        <a href="/camiones"   class="sidebar-link <%= modulo==='camiones'  ?'active':'' %>"><i class="bi bi-truck-front"></i> Camiones</a>
      </div>
    </div>

    <div class="sidebar-group" data-group="tarifas">
      <div class="sidebar-section sidebar-toggle">
        <span>Tarifas</span>
        <i class="bi bi-chevron-down sidebar-chevron"></i>
      </div>
      <div class="sidebar-group-body">
        <a href="/tarifas"    class="sidebar-link <%= modulo==='tarifas'   ?'active':'' %>"><i class="bi bi-currency-dollar"></i> Tarifas</a>
        <a href="/tarkilomts" class="sidebar-link <%= modulo==='tarkilomts'?'active':'' %>"><i class="bi bi-speedometer2"></i> Tarifas x Km</a>
        <a href="/dieselpre"  class="sidebar-link <%= modulo==='dieselpre' ?'active':'' %>"><i class="bi bi-fuel-pump"></i> Precios Diesel</a>
      </div>
    </div>

  </div>

  <div class="p-2 border-top border-secondary">
    <a href="/logout" class="sidebar-link text-danger"><i class="bi bi-box-arrow-left"></i> Cerrar sesión</a>
  </div>
</nav>
