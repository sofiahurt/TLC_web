<%- include('partials/header', { titulo: 'Operadores' }) %>
<%- include('partials/sidebar') %>
<div id="page-content">
  <div class="d-flex align-items-center mb-3">
    <button class="btn btn-sm btn-outline-secondary me-3 d-md-none" id="sidebarToggle"><i class="bi bi-list fs-5"></i></button>
    <h4 class="mb-0 fw-bold flex-grow-1">Operadores</h4>
  </div>
  <div class="card border-0 shadow-sm mb-3"><div class="card-body py-2">
    <div class="row align-items-center g-2">
      <div class="col-auto"><select id="searchCol" class="form-select form-select-sm">
        <option value="OPERADOR">Nombre</option><option value="RFC">RFC</option><option value="CIUDAD">Ciudad</option><option value="STATUS">Estatus</option>
      </select></div>
      <div class="col col-md-4"><input type="text" id="searchInput" class="form-control form-select-sm" placeholder="Buscar..."></div>
      <div class="col-auto ms-auto btn-action-group">
        <button class="btn btn-sm btn-success" onclick="openAdd()"><i class="bi bi-plus-lg"></i> Agregar</button>
        <button class="btn btn-sm btn-primary" data-requires-selection disabled onclick="openEdit()"><i class="bi bi-pencil"></i> Editar</button>
        <button class="btn btn-sm btn-danger" data-requires-selection disabled onclick="confirmDelete()"><i class="bi bi-trash"></i> Eliminar</button>
      </div>
    </div>
  </div></div>
  <div class="card border-0 shadow-sm"><div class="card-body p-0">
    <div class="table-responsive"><table class="table table-hover table-sm mb-0">
      <thead class="thead-tlc"><tr>
        <th data-sort="ID_OPERADOR" style="width:80px">ID <span class="sort-icon"></span></th>
        <th data-sort="OPERADOR">Operador <span class="sort-icon"></span></th>
        <th data-sort="RFC">RFC <span class="sort-icon"></span></th>
        <th data-sort="CIUDAD">Ciudad <span class="sort-icon"></span></th>
        <th data-sort="STATUS" style="width:100px">Estatus <span class="sort-icon"></span></th>
      </tr></thead>
      <tbody id="tableBody"></tbody>
    </table></div>
  </div>
  <div class="card-footer bg-white d-flex align-items-center justify-content-between py-2">
    <span class="page-info" id="pageInfo"></span>
    <div id="pagination">
      <button class="btn btn-sm btn-outline-secondary" data-action="prev"><i class="bi bi-chevron-left"></i> Anterior</button>
      <button class="btn btn-sm btn-outline-secondary" data-action="next">Siguiente <i class="bi bi-chevron-right"></i></button>
    </div>
  </div></div>
</div>

<!-- Modal Formulario -->
<div class="modal fade" id="frmModal" tabindex="-1"><div class="modal-dialog modal-dialog-centered modal-xl">
  <div class="modal-content">
    <div class="modal-header"><h5 class="modal-title" id="frmTitle">Operador</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
    <div class="modal-body">
      <div id="frmError" class="alert alert-danger d-none py-2 small"></div>
      <div class="row g-3">
        <div class="col-md-2"><label class="form-label fw-semibold">ID <span class="text-danger">*</span></label><input type="number" id="f_ID" class="form-control"></div>
        <div class="col-md-6"><label class="form-label fw-semibold">Nombre completo <span class="text-danger">*</span></label><input type="text" id="f_OPERADOR" class="form-control" maxlength="254"></div>
        <div class="col-md-2"><label class="form-label fw-semibold">RFC</label><input type="text" id="f_RFC" class="form-control" maxlength="18"></div>
        <div class="col-md-2"><label class="form-label fw-semibold">No. Licencia</label><input type="text" id="f_NOLICENCIA" class="form-control" maxlength="16"></div>
        <div class="col-md-4"><label class="form-label fw-semibold">Calle</label><input type="text" id="f_CALLE" class="form-control" maxlength="100"></div>
        <div class="col-md-2"><label class="form-label fw-semibold">No. Ext</label><input type="text" id="f_NOEXT" class="form-control" maxlength="20"></div>
        <div class="col-md-2"><label class="form-label fw-semibold">No. Int</label><input type="text" id="f_NOINT" class="form-control" maxlength="20"></div>
        <div class="col-md-4"><label class="form-label fw-semibold">Colonia</label><input type="text" id="f_COLONIA" class="form-control" maxlength="150"></div>
        <div class="col-md-4"><label class="form-label fw-semibold">Ciudad</label><input type="text" id="f_CIUDAD" class="form-control" maxlength="150"></div>
        <div class="col-md-4"><label class="form-label fw-semibold">Municipio</label><input type="text" id="f_MUNICIPIO" class="form-control" maxlength="40"></div>
        <div class="col-md-2"><label class="form-label fw-semibold">Estado</label><input type="text" id="f_ESTADO" class="form-control" maxlength="30"></div>
        <div class="col-md-2"><label class="form-label fw-semibold">País</label><input type="text" id="f_PAIS" class="form-control" maxlength="20"></div>
        <div class="col-md-2"><label class="form-label fw-semibold">C.P.</label><input type="text" id="f_CP" class="form-control" maxlength="5"></div>
        <div class="col-md-2"><label class="form-label fw-semibold">Teléfono</label><input type="text" id="f_TELEFONO" class="form-control" maxlength="15"></div>
        <div class="col-md-2"><label class="form-label fw-semibold">Nextel</label><input type="text" id="f_NEXTEL" class="form-control" maxlength="15"></div>
        <div class="col-md-2"><label class="form-label fw-semibold">Celular</label><input type="text" id="f_CELULAR" class="form-control" maxlength="15"></div>
        <div class="col-md-3"><label class="form-label fw-semibold">Infonavit</label><input type="number" id="f_INFONAVIT" class="form-control" step="0.01"></div>
        <div class="col-md-3"><label class="form-label fw-semibold">Tipo Desc. Infonavit</label><input type="text" id="f_TIPODESINFONAVIT" class="form-control" maxlength="20"></div>
        <div class="col-md-2"><label class="form-label fw-semibold">Fecha Baja</label><input type="date" id="f_FECHABAJA" class="form-control"></div>
        <div class="col-md-2"><label class="form-label fw-semibold">Estatus</label><input type="text" id="f_STATUS" class="form-control" maxlength="20"></div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i> Cancelar</button>
      <button class="btn btn-primary" onclick="guardar()"><i class="bi bi-floppy"></i> Guardar</button>
    </div>
  </div>
</div></div>

<%- include('partials/footer') %>
<script>
const browse=initBrowse({searchInput:document.getElementById('searchInput'),searchColumn:document.getElementById('searchCol'),tableBody:document.getElementById('tableBody'),paginationEl:document.getElementById('pagination'),infoEl:document.getElementById('pageInfo'),fetchUrl:'/operadores/data'});
let _mode='add';const modal=new bootstrap.Modal(document.getElementById('frmModal'));
const flds=['ID','OPERADOR','RFC','NOLICENCIA','CALLE','NOEXT','NOINT','COLONIA','CIUDAD','MUNICIPIO','ESTADO','PAIS','CP','TELEFONO','NEXTEL','CELULAR','INFONAVIT','TIPODESINFONAVIT','FECHABAJA','STATUS'];
function clearForm(){flds.forEach(f=>document.getElementById('f_'+f).value='');}
function openAdd(){_mode='add';document.getElementById('frmTitle').textContent='Nuevo Operador';clearForm();document.getElementById('f_ID').readOnly=false;document.getElementById('frmError').classList.add('d-none');modal.show();}
function openEdit(){if(!window._selectedRow)return;_mode='edit';document.getElementById('frmTitle').textContent='Editar Operador';const r=window._selectedRow;document.getElementById('f_ID').value=r.ID_OPERADOR;document.getElementById('f_OPERADOR').value=r.OPERADOR||'';document.getElementById('f_RFC').value=r.RFC||'';document.getElementById('f_NOLICENCIA').value=r.NOLICENCIA||'';document.getElementById('f_CIUDAD').value=r.CIUDAD||'';document.getElementById('f_STATUS').value=r.STATUS||'';document.getElementById('f_FECHABAJA').value=r.FECHABAJA||'';document.getElementById('f_TELEFONO').value=r.TELEFONO||'';document.getElementById('f_CELULAR').value=r.CELULAR||'';document.getElementById('f_ID').readOnly=true;document.getElementById('frmError').classList.add('d-none');modal.show();}
function guardar(){const id=document.getElementById('f_ID').value.trim(),ope=document.getElementById('f_OPERADOR').value.trim(),errEl=document.getElementById('frmError');if(!id||!ope){errEl.textContent='ID y Nombre son requeridos.';errEl.classList.remove('d-none');return;}const body={_mode,ID_OPERADOR:id,OPERADOR:ope,RFC:document.getElementById('f_RFC').value,NOLICENCIA:document.getElementById('f_NOLICENCIA').value,CALLE:document.getElementById('f_CALLE').value,NOEXT:document.getElementById('f_NOEXT').value,NOINT:document.getElementById('f_NOINT').value,COLONIA:document.getElementById('f_COLONIA').value,CIUDAD:document.getElementById('f_CIUDAD').value,MUNICIPIO:document.getElementById('f_MUNICIPIO').value,ESTADO:document.getElementById('f_ESTADO').value,PAIS:document.getElementById('f_PAIS').value,CP:document.getElementById('f_CP').value,TELEFONO:document.getElementById('f_TELEFONO').value,NEXTEL:document.getElementById('f_NEXTEL').value,CELULAR:document.getElementById('f_CELULAR').value,INFONAVIT:document.getElementById('f_INFONAVIT').value,TIPODESINFONAVIT:document.getElementById('f_TIPODESINFONAVIT').value,FECHABAJA:document.getElementById('f_FECHABAJA').value,STATUS:document.getElementById('f_STATUS').value};fetch('/operadores/guardar',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)}).then(r=>r.json()).then(d=>{if(d.error){errEl.textContent=d.error;errEl.classList.remove('d-none');return;}modal.hide();browse.load();});}
function confirmDelete(){if(!window._selectedRow)return;if(!confirm(`¿Eliminar operador "${window._selectedRow.OPERADOR}"?`))return;fetch('/operadores/eliminar',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({ID_OPERADOR:window._selectedRow.ID_OPERADOR})}).then(r=>r.json()).then(d=>{if(!d.error)browse.load();});}
</script>
