<%- include('partials/header', { titulo: 'Transportistas' }) %>
<%- include('partials/sidebar') %>
<div id="page-content">
  <div class="d-flex align-items-center mb-3">
    <button class="btn btn-sm btn-outline-secondary me-3 d-md-none" id="sidebarToggle"><i class="bi bi-list fs-5"></i></button>
    <h4 class="mb-0 fw-bold flex-grow-1">Transportistas</h4>
  </div>
  <div class="card border-0 shadow-sm mb-3"><div class="card-body py-2">
    <div class="row align-items-center g-2">
      <div class="col-auto"><select id="searchCol" class="form-select form-select-sm">
        <option value="NOMBRECOMUN">Nombre corto</option><option value="NOMBRECOM">Razón social</option><option value="RFC">RFC</option><option value="CIUDAD">Ciudad</option>
      </select></div>
      <div class="col col-md-4"><input type="text" id="searchInput" class="form-control form-select-sm" placeholder="Buscar..."></div>
      <div class="col-auto ms-auto btn-action-group">
        <button class="btn btn-sm btn-success" onclick="openAdd()"><i class="bi bi-plus-lg"></i> Agregar</button>
        <button class="btn btn-sm btn-primary" data-requires-selection disabled onclick="openEdit()"><i class="bi bi-pencil"></i> Editar</button>
        <button class="btn btn-sm btn-danger" data-requires-selection disabled onclick="confirmDelete()"><i class="bi bi-trash"></i> Eliminar</button>
      </div>
    </div>
  </div></div>
  <div class="card border-0 shadow-sm"><div class="card-body p-0">
    <div class="table-responsive"><table class="table table-hover table-sm mb-0">
      <thead class="thead-tlc"><tr>
        <th data-sort="ID_TRANSPORTISTA" style="width:80px">ID <span class="sort-icon"></span></th>
        <th data-sort="NOMBRECOMUN">Nombre corto <span class="sort-icon"></span></th>
        <th data-sort="NOMBRECOM">Razón social <span class="sort-icon"></span></th>
        <th data-sort="RFC" style="width:120px">RFC <span class="sort-icon"></span></th>
        <th data-sort="CIUDAD">Ciudad <span class="sort-icon"></span></th>
        <th data-sort="CP" style="width:80px">C.P. <span class="sort-icon"></span></th>
      </tr></thead>
      <tbody id="tableBody"></tbody>
    </table></div>
  </div>
  <div class="card-footer bg-white d-flex align-items-center justify-content-between py-2">
    <span class="page-info" id="pageInfo"></span>
    <div id="pagination">
      <button class="btn btn-sm btn-outline-secondary" data-action="prev"><i class="bi bi-chevron-left"></i> Anterior</button>
      <button class="btn btn-sm btn-outline-secondary" data-action="next">Siguiente <i class="bi bi-chevron-right"></i></button>
    </div>
  </div></div>
</div>

<!-- Modal Formulario -->
<div class="modal fade" id="frmModal" tabindex="-1"><div class="modal-dialog modal-dialog-centered modal-xl">
  <div class="modal-content">
    <div class="modal-header"><h5 class="modal-title" id="frmTitle">Transportista</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
    <div class="modal-body">
      <div id="frmError" class="alert alert-danger d-none py-2 small"></div>
      <div class="row g-3">
        <div class="col-md-2"><label class="form-label fw-semibold">ID <span class="text-danger">*</span></label><input type="number" id="f_ID" class="form-control"></div>
        <div class="col-md-5"><label class="form-label fw-semibold">Razón social</label><input type="text" id="f_NOMBRECOM" class="form-control" maxlength="150"></div>
        <div class="col-md-5"><label class="form-label fw-semibold">Nombre corto <span class="text-danger">*</span></label><input type="text" id="f_NOMBRECOMUN" class="form-control" maxlength="80"></div>
        <div class="col-md-6"><label class="form-label fw-semibold">Dirección</label><input type="text" id="f_CALLENUM" class="form-control" maxlength="150"></div>
        <div class="col-md-2"><label class="form-label fw-semibold">RFC</label><input type="text" id="f_RFC" class="form-control" maxlength="15"></div>
        <div class="col-md-4"><label class="form-label fw-semibold">Ciudad</label><input type="text" id="f_CIUDAD" class="form-control" maxlength="80"></div>
        <!-- Colonia lookup -->
        <div class="col-md-4">
          <label class="form-label fw-semibold">Colonia</label>
          <div class="input-group">
            <input type="hidden" id="f_ID_COLONIA">
            <input type="text" id="f_COLONIA" class="form-control" maxlength="80" placeholder="Seleccionar...">
            <button class="btn btn-outline-secondary" type="button" onclick="openLookupColonia()"><i class="bi bi-search"></i></button>
          </div>
        </div>
        <div class="col-md-2"><label class="form-label fw-semibold">C.P.</label><input type="text" id="f_CP" class="form-control" maxlength="6"></div>
        <div class="col-md-4"><label class="form-label fw-semibold">Realizó</label><input type="text" id="f_REALIZO" class="form-control" maxlength="60"></div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i> Cancelar</button>
      <button class="btn btn-primary" onclick="guardar()"><i class="bi bi-floppy"></i> Guardar</button>
    </div>
  </div>
</div></div>

<!-- Lookup Colonias -->
<div class="modal fade modal-lookup" id="lookupColonia" tabindex="-1"><div class="modal-dialog modal-dialog-centered modal-lg">
  <div class="modal-content">
    <div class="modal-header py-2"><h6 class="modal-title">Seleccionar Colonia</h6><button class="btn-close" data-bs-dismiss="modal"></button></div>
    <div class="modal-body">
      <input type="text" id="lkColQ" class="form-control form-control-sm mb-2" placeholder="Buscar colonia o C.P...">
      <table class="table table-hover table-sm"><thead class="table-secondary"><tr><th>ID</th><th>Colonia</th><th>C.P.</th></tr></thead>
      <tbody id="lkColBody"></tbody></table>
      <div class="d-flex justify-content-between align-items-center">
        <span id="lkColInfo" class="small text-muted"></span>
        <div><button class="btn btn-sm btn-outline-secondary" id="lkColPrev">‹</button> <button class="btn btn-sm btn-outline-secondary" id="lkColNext">›</button></div>
      </div>
    </div>
  </div>
</div></div>

<%- include('partials/footer') %>
<script>
const browse=initBrowse({searchInput:document.getElementById('searchInput'),searchColumn:document.getElementById('searchCol'),tableBody:document.getElementById('tableBody'),paginationEl:document.getElementById('pagination'),infoEl:document.getElementById('pageInfo'),fetchUrl:'/transport/data'});
let _mode='add';const modal=new bootstrap.Modal(document.getElementById('frmModal'));
function openAdd(){_mode='add';document.getElementById('frmTitle').textContent='Nuevo Transportista';['f_ID','f_NOMBRECOM','f_NOMBRECOMUN','f_CALLENUM','f_RFC','f_CIUDAD','f_COLONIA','f_CP','f_REALIZO'].forEach(i=>document.getElementById(i).value='');document.getElementById('f_ID_COLONIA').value='';document.getElementById('f_ID').readOnly=false;document.getElementById('frmError').classList.add('d-none');modal.show();}
function openEdit(){if(!window._selectedRow)return;_mode='edit';document.getElementById('frmTitle').textContent='Editar Transportista';const r=window._selectedRow;document.getElementById('f_ID').value=r.ID_TRANSPORTISTA;document.getElementById('f_NOMBRECOM').value=r.NOMBRECOM||'';document.getElementById('f_NOMBRECOMUN').value=r.NOMBRECOMUN||'';document.getElementById('f_RFC').value=r.RFC||'';document.getElementById('f_CIUDAD').value=r.CIUDAD||'';document.getElementById('f_CP').value=r.CP||'';document.getElementById('f_COLONIA').value=r.COLONIA||'';document.getElementById('f_ID').readOnly=true;document.getElementById('frmError').classList.add('d-none');modal.show();}
function guardar(){const id=document.getElementById('f_ID').value.trim(),ncomun=document.getElementById('f_NOMBRECOMUN').value.trim(),errEl=document.getElementById('frmError');if(!id||!ncomun){errEl.textContent='ID y Nombre corto son requeridos.';errEl.classList.remove('d-none');return;}fetch('/transport/guardar',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({_mode,ID_TRANSPORTISTA:id,NOMBRECOM:document.getElementById('f_NOMBRECOM').value,NOMBRECOMUN:ncomun,CALLENUM:document.getElementById('f_CALLENUM').value,ID_COLONIA:document.getElementById('f_ID_COLONIA').value,COLONIA:document.getElementById('f_COLONIA').value,CP:document.getElementById('f_CP').value,CIUDAD:document.getElementById('f_CIUDAD').value,RFC:document.getElementById('f_RFC').value,REALIZO:document.getElementById('f_REALIZO').value})}).then(r=>r.json()).then(d=>{if(d.error){errEl.textContent=d.error;errEl.classList.remove('d-none');return;}modal.hide();browse.load();});}
function confirmDelete(){if(!window._selectedRow)return;if(!confirm(`¿Eliminar transportista "${window._selectedRow.NOMBRECOMUN}"?`))return;fetch('/transport/eliminar',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({ID_TRANSPORTISTA:window._selectedRow.ID_TRANSPORTISTA})}).then(r=>r.json()).then(d=>{if(!d.error)browse.load();});}

// Lookup colonia
let lkColPage=1;
const lkColModal=new bootstrap.Modal(document.getElementById('lookupColonia'));
function openLookupColonia(){lkColPage=1;document.getElementById('lkColQ').value='';loadLkCol();lkColModal.show();}
function loadLkCol(){const q=document.getElementById('lkColQ').value;fetch(`/transport/lookup/colonias?q=${encodeURIComponent(q)}&page=${lkColPage}`).then(r=>r.json()).then(d=>{document.getElementById('lkColBody').innerHTML=d.rows.map(r=>`<tr data-id="${r.ID_COLONIA}" data-col="${(r.COLONIA||'').trim()}" data-cp="${(r.CP||'').trim()}" style="cursor:pointer"><td>${r.ID_COLONIA}</td><td>${(r.COLONIA||'').trim()}</td><td>${(r.CP||'').trim()}</td></tr>`).join('');document.getElementById('lkColInfo').textContent=`Pág ${d.page}/${d.totalPages}`;document.getElementById('lkColPrev').disabled=d.page<=1;document.getElementById('lkColNext').disabled=d.page>=d.totalPages;});}
document.getElementById('lkColQ').addEventListener('input',debounce(()=>{lkColPage=1;loadLkCol();},300));
document.getElementById('lkColPrev').addEventListener('click',()=>{if(lkColPage>1){lkColPage--;loadLkCol();}});
document.getElementById('lkColNext').addEventListener('click',()=>{lkColPage++;loadLkCol();});
document.getElementById('lkColBody').addEventListener('click',e=>{const row=e.target.closest('tr[data-id]');if(!row)return;document.getElementById('f_ID_COLONIA').value=row.dataset.id;document.getElementById('f_COLONIA').value=row.dataset.col;document.getElementById('f_CP').value=row.dataset.cp;lkColModal.hide();});
</script>
