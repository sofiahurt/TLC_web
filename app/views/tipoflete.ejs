<%- include('partials/header', { titulo: 'Tipos de Flete' }) %>
<%- include('partials/sidebar') %>
<div id="page-content">
  <div class="d-flex align-items-center mb-3">
    <button class="btn btn-sm btn-outline-secondary me-3 d-md-none" id="sidebarToggle"><i class="bi bi-list fs-5"></i></button>
    <h4 class="mb-0 fw-bold flex-grow-1">Tipos de Flete</h4>
  </div>
  <div class="card border-0 shadow-sm mb-3"><div class="card-body py-2">
    <div class="row align-items-center g-2">
      <div class="col-auto"><select id="searchCol" class="form-select form-select-sm"><option value="FLETE">Flete</option><option value="ID_TIPOFLETE">ID</option></select></div>
      <div class="col col-md-4"><input type="text" id="searchInput" class="form-control form-select-sm" placeholder="Buscar..."></div>
      <div class="col-auto ms-auto btn-action-group">
        <button class="btn btn-sm btn-success" onclick="openAdd()"><i class="bi bi-plus-lg"></i> Agregar</button>
        <button class="btn btn-sm btn-primary" data-requires-selection disabled onclick="openEdit()"><i class="bi bi-pencil"></i> Editar</button>
        <button class="btn btn-sm btn-danger" data-requires-selection disabled onclick="confirmDelete()"><i class="bi bi-trash"></i> Eliminar</button>
      </div>
    </div>
  </div></div>
  <div class="card border-0 shadow-sm"><div class="card-body p-0">
    <div class="table-responsive"><table class="table table-hover table-sm mb-0">
      <thead class="table-dark"><tr>
        <th data-sort="ID_TIPOFLETE" style="width:120px">ID <span class="sort-icon"></span></th>
        <th data-sort="FLETE">Tipo de Flete <span class="sort-icon"></span></th>
      </tr></thead>
      <tbody id="tableBody"></tbody>
    </table></div>
  </div>
  <div class="card-footer bg-white d-flex align-items-center justify-content-between py-2">
    <span class="page-info" id="pageInfo"></span>
    <div id="pagination">
      <button class="btn btn-sm btn-outline-secondary" data-action="prev"><i class="bi bi-chevron-left"></i> Anterior</button>
      <button class="btn btn-sm btn-outline-secondary" data-action="next">Siguiente <i class="bi bi-chevron-right"></i></button>
    </div>
  </div></div>
</div>
<div class="modal fade" id="frmModal" tabindex="-1"><div class="modal-dialog modal-dialog-centered">
  <div class="modal-content">
    <div class="modal-header"><h5 class="modal-title" id="frmTitle">Tipo de Flete</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
    <div class="modal-body">
      <div id="frmError" class="alert alert-danger d-none py-2 small"></div>
      <div class="row g-3">
        <div class="col-4"><label class="form-label fw-semibold">ID <span class="text-danger">*</span></label><input type="number" id="f_ID" class="form-control"></div>
        <div class="col-8"><label class="form-label fw-semibold">Tipo de Flete <span class="text-danger">*</span></label><input type="text" id="f_FLETE" class="form-control" maxlength="50"></div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i> Cancelar</button>
      <button class="btn btn-primary" onclick="guardar()"><i class="bi bi-floppy"></i> Guardar</button>
    </div>
  </div>
</div></div>
<%- include('partials/footer') %>
<script>
const browse=initBrowse({searchInput:document.getElementById('searchInput'),searchColumn:document.getElementById('searchCol'),tableBody:document.getElementById('tableBody'),paginationEl:document.getElementById('pagination'),infoEl:document.getElementById('pageInfo'),fetchUrl:'/tipoflete/data'});
let _mode='add';const modal=new bootstrap.Modal(document.getElementById('frmModal'));
function openAdd(){_mode='add';document.getElementById('frmTitle').textContent='Nuevo Tipo de Flete';document.getElementById('f_ID').value='';document.getElementById('f_FLETE').value='';document.getElementById('f_ID').readOnly=false;document.getElementById('frmError').classList.add('d-none');modal.show();}
function openEdit(){if(!window._selectedRow)return;_mode='edit';document.getElementById('frmTitle').textContent='Editar Tipo de Flete';document.getElementById('f_ID').value=window._selectedRow.ID_TIPOFLETE;document.getElementById('f_FLETE').value=window._selectedRow.FLETE;document.getElementById('f_ID').readOnly=true;document.getElementById('frmError').classList.add('d-none');modal.show();}
function guardar(){const id=document.getElementById('f_ID').value.trim(),flete=document.getElementById('f_FLETE').value.trim(),errEl=document.getElementById('frmError');if(!id||!flete){errEl.textContent='ID y Tipo de Flete son requeridos.';errEl.classList.remove('d-none');return;}fetch('/tipoflete/guardar',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({ID_TIPOFLETE:id,FLETE:flete,_mode})}).then(r=>r.json()).then(d=>{if(d.error){errEl.textContent=d.error;errEl.classList.remove('d-none');return;}modal.hide();browse.load();});}
function confirmDelete(){if(!window._selectedRow)return;if(!confirm(`¿Eliminar el tipo "${window._selectedRow.FLETE}"?`))return;fetch('/tipoflete/eliminar',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({ID_TIPOFLETE:window._selectedRow.ID_TIPOFLETE})}).then(r=>r.json()).then(d=>{if(!d.error)browse.load();});}
</script>
