<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>TLC Web — Seleccionar año</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <style>
    body { background: #1e2a38; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    .anio-card { width: 100%; max-width: 400px; }
    .anio-spinner { background: #14202e; border-radius: 8px; }
  </style>
</head>
<body>
<div class="anio-card">
  <div class="card shadow-lg border-0">
    <div class="card-body p-4">

      <div class="text-center mb-3">
        <i class="bi bi-truck fs-1 text-primary"></i>
        <h4 class="mt-2 fw-bold">TLC Web</h4>
        <p class="text-muted small mb-2">Selecciona el año de trabajo</p>
        <div class="d-flex align-items-center justify-content-center gap-2">
          <span class="text-secondary small"><i class="bi bi-person-circle me-1"></i><%= usuario.nombre.trim() %></span>
          <% if (usuario.serie) { %>
            <span class="badge bg-primary">Serie: <%= usuario.serie.trim() %></span>
          <% } %>
        </div>
      </div>

      <form method="POST" action="/seleccionar-anio">
        <input type="hidden" name="anio" id="anioInput">

        <div class="anio-spinner p-4 mb-4 text-center">
          <div class="d-flex align-items-center justify-content-center gap-3">
            <button type="button" class="btn btn-outline-light btn-lg px-3" id="btnPrev">&#8249;</button>
            <span class="fs-2 fw-bold text-white" id="anioDisplay" style="min-width:90px">—</span>
            <button type="button" class="btn btn-outline-light btn-lg px-3" id="btnNext">&#8250;</button>
          </div>
        </div>

        <button type="submit" class="btn btn-primary w-100 fw-semibold">
          <i class="bi bi-calendar-check me-1"></i>Continuar
        </button>
      </form>

    </div>
    <div class="card-footer text-center bg-transparent border-top-0 pb-3">
      <a href="/logout" class="text-muted small text-decoration-none">
        <i class="bi bi-box-arrow-left me-1"></i>Cerrar sesión
      </a>
    </div>
  </div>
</div>

<script>
  const MIN = 2000;
  const MAX = new Date().getFullYear() + 1;
  let anio = new Date().getFullYear();

  function updateDisplay() {
    document.getElementById('anioDisplay').textContent = anio;
    document.getElementById('anioInput').value = anio;
    document.getElementById('btnPrev').disabled = anio <= MIN;
    document.getElementById('btnNext').disabled = anio >= MAX;
  }

  document.getElementById('btnPrev').addEventListener('click', () => { if (anio > MIN) { anio--; updateDisplay(); } });
  document.getElementById('btnNext').addEventListener('click', () => { if (anio < MAX) { anio++; updateDisplay(); } });

  updateDisplay();
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
