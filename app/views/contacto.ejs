<%- include('partials/header', { titulo: 'Contactos' }) %>
<%- include('partials/sidebar') %>
<div id="page-content">
  <div class="d-flex align-items-center mb-3">
    <button class="btn btn-sm btn-outline-secondary me-3 d-md-none" id="sidebarToggle"><i class="bi bi-list fs-5"></i></button>
    <h4 class="mb-0 fw-bold flex-grow-1">Contactos</h4>
  </div>
  <div class="card border-0 shadow-sm mb-3"><div class="card-body py-2">
    <div class="row align-items-center g-2">
      <div class="col-auto"><select id="searchCol" class="form-select form-select-sm">
        <option value="CONTACTO">Contacto</option><option value="EMAIL">Email</option><option value="AREA">Área</option><option value="ID_CLIENTE">ID Cliente</option>
      </select></div>
      <div class="col col-md-4"><input type="text" id="searchInput" class="form-control form-select-sm" placeholder="Buscar..."></div>
      <div class="col-auto ms-auto btn-action-group">
        <button class="btn btn-sm btn-success" onclick="openAdd()"><i class="bi bi-plus-lg"></i> Agregar</button>
        <button class="btn btn-sm btn-primary" data-requires-selection disabled onclick="openEdit()"><i class="bi bi-pencil"></i> Editar</button>
        <button class="btn btn-sm btn-danger" data-requires-selection disabled onclick="confirmDelete()"><i class="bi bi-trash"></i> Eliminar</button>
      </div>
    </div>
  </div></div>
  <div class="card border-0 shadow-sm"><div class="card-body p-0">
    <div class="table-responsive"><table class="table table-hover table-sm mb-0">
      <thead class="thead-tlc"><tr>
        <th data-sort="ID_CLIENTE" style="width:90px">ID Cliente <span class="sort-icon"></span></th>
        <th data-sort="ID_CONTACTO" style="width:70px">ID Con. <span class="sort-icon"></span></th>
        <th data-sort="CONTACTO">Contacto <span class="sort-icon"></span></th>
        <th data-sort="EMAIL">Email <span class="sort-icon"></span></th>
        <th data-sort="AREA">Área <span class="sort-icon"></span></th>
        <th data-sort="TELEFONO1">Teléfono <span class="sort-icon"></span></th>
      </tr></thead>
      <tbody id="tableBody"></tbody>
    </table></div>
  </div>
  <div class="card-footer bg-white d-flex align-items-center justify-content-between py-2">
    <span class="page-info" id="pageInfo"></span>
    <div id="pagination">
      <button class="btn btn-sm btn-outline-secondary" data-action="prev"><i class="bi bi-chevron-left"></i> Anterior</button>
      <button class="btn btn-sm btn-outline-secondary" data-action="next">Siguiente <i class="bi bi-chevron-right"></i></button>
    </div>
  </div></div>
</div>

<div class="modal fade" id="frmModal" tabindex="-1"><div class="modal-dialog modal-dialog-centered modal-lg">
  <div class="modal-content">
    <div class="modal-header"><h5 class="modal-title" id="frmTitle">Contacto</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
    <div class="modal-body">
      <div id="frmError" class="alert alert-danger d-none py-2 small"></div>
      <div class="row g-3">
        <!-- Cliente lookup -->
        <div class="col-md-5">
          <label class="form-label fw-semibold">Cliente <span class="text-danger">*</span></label>
          <div class="input-group">
            <input type="hidden" id="f_ID_CLIENTE">
            <input type="text" id="f_NOMBRECOMUN" class="form-control" placeholder="Seleccionar cliente..." readonly>
            <button class="btn btn-outline-secondary" type="button" onclick="openLookupCli()"><i class="bi bi-search"></i></button>
          </div>
        </div>
        <div class="col-md-2"><label class="form-label fw-semibold">ID Con. <span class="text-danger">*</span></label><input type="number" id="f_ID_CONTACTO" class="form-control"></div>
        <div class="col-md-5"><label class="form-label fw-semibold">Nombre Contacto</label><input type="text" id="f_CONTACTO" class="form-control" maxlength="60"></div>
        <div class="col-md-5"><label class="form-label fw-semibold">Email</label><input type="text" id="f_EMAIL" class="form-control" maxlength="64"></div>
        <div class="col-md-4"><label class="form-label fw-semibold">Área</label><input type="text" id="f_AREA" class="form-control" maxlength="45"></div>
        <div class="col-md-3"><label class="form-label fw-semibold">Tipo Tel 1</label><input type="text" id="f_TIPOTEL1" class="form-control" maxlength="10"></div>
        <div class="col-md-3"><label class="form-label fw-semibold">Teléfono 1</label><input type="text" id="f_TELEFONO1" class="form-control" maxlength="20"></div>
        <div class="col-md-3"><label class="form-label fw-semibold">Tipo Tel 2</label><input type="text" id="f_TIPOTEL2" class="form-control" maxlength="10"></div>
        <div class="col-md-3"><label class="form-label fw-semibold">Teléfono 2</label><input type="text" id="f_TELEFONO2" class="form-control" maxlength="20"></div>
        <div class="col-md-3"><label class="form-label fw-semibold">Tipo Tel 3</label><input type="text" id="f_TIPOTEL3" class="form-control" maxlength="10"></div>
        <div class="col-md-3"><label class="form-label fw-semibold">Teléfono 3</label><input type="text" id="f_TELEFONO3" class="form-control" maxlength="20"></div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i> Cancelar</button>
      <button class="btn btn-primary" onclick="guardar()"><i class="bi bi-floppy"></i> Guardar</button>
    </div>
  </div>
</div></div>

<!-- Lookup Clientes -->
<div class="modal fade modal-lookup" id="lookupCli" tabindex="-1"><div class="modal-dialog modal-dialog-centered modal-lg">
  <div class="modal-content">
    <div class="modal-header py-2"><h6 class="modal-title">Seleccionar Cliente</h6><button class="btn-close" data-bs-dismiss="modal"></button></div>
    <div class="modal-body">
      <input type="text" id="lkCliQ" class="form-control form-control-sm mb-2" placeholder="Buscar cliente...">
      <table class="table table-hover table-sm"><thead class="table-secondary"><tr><th>ID</th><th>Nombre</th><th>RFC</th></tr></thead>
      <tbody id="lkCliBody"></tbody></table>
      <div class="d-flex justify-content-between align-items-center">
        <span id="lkCliInfo" class="small text-muted"></span>
        <div><button class="btn btn-sm btn-outline-secondary" id="lkCliPrev">‹</button> <button class="btn btn-sm btn-outline-secondary" id="lkCliNext">›</button></div>
      </div>
    </div>
  </div>
</div></div>

<%- include('partials/footer') %>
<script>
const browse=initBrowse({searchInput:document.getElementById('searchInput'),searchColumn:document.getElementById('searchCol'),tableBody:document.getElementById('tableBody'),paginationEl:document.getElementById('pagination'),infoEl:document.getElementById('pageInfo'),fetchUrl:'/contacto/data'});
let _mode='add';const modal=new bootstrap.Modal(document.getElementById('frmModal'));
const flds=['ID_CONTACTO','CONTACTO','EMAIL','AREA','TIPOTEL1','TELEFONO1','TIPOTEL2','TELEFONO2','TIPOTEL3','TELEFONO3'];
function clearForm(){flds.forEach(f=>document.getElementById('f_'+f).value='');document.getElementById('f_ID_CLIENTE').value='';document.getElementById('f_NOMBRECOMUN').value='';}
function openAdd(){_mode='add';document.getElementById('frmTitle').textContent='Nuevo Contacto';clearForm();document.getElementById('f_ID_CONTACTO').readOnly=false;document.getElementById('frmError').classList.add('d-none');modal.show();}
function openEdit(){if(!window._selectedRow)return;_mode='edit';const r=window._selectedRow;document.getElementById('frmTitle').textContent='Editar Contacto';clearForm();document.getElementById('f_ID_CLIENTE').value=r.ID_CLIENTE;document.getElementById('f_NOMBRECOMUN').value='';document.getElementById('f_ID_CONTACTO').value=r.ID_CONTACTO;document.getElementById('f_CONTACTO').value=r.CONTACTO||'';document.getElementById('f_EMAIL').value=r.EMAIL||'';document.getElementById('f_AREA').value=r.AREA||'';document.getElementById('f_TELEFONO1').value=r.TELEFONO1||'';document.getElementById('f_TIPOTEL1').value=r.TIPOTEL1||'';document.getElementById('f_ID_CONTACTO').readOnly=true;document.getElementById('frmError').classList.add('d-none');modal.show();}
function guardar(){const idcli=document.getElementById('f_ID_CLIENTE').value,idcon=document.getElementById('f_ID_CONTACTO').value,errEl=document.getElementById('frmError');if(!idcli||!idcon){errEl.textContent='Cliente e ID de contacto son requeridos.';errEl.classList.remove('d-none');return;}const body={_mode,ID_CLIENTE:idcli,ID_CONTACTO:idcon};flds.slice(1).forEach(f=>body[f]=document.getElementById('f_'+f).value);fetch('/contacto/guardar',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)}).then(r=>r.json()).then(d=>{if(d.error){errEl.textContent=d.error;errEl.classList.remove('d-none');return;}modal.hide();browse.load();});}
function confirmDelete(){if(!window._selectedRow)return;if(!confirm('¿Eliminar este contacto?'))return;fetch('/contacto/eliminar',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({ID_CLIENTE:window._selectedRow.ID_CLIENTE,ID_CONTACTO:window._selectedRow.ID_CONTACTO})}).then(r=>r.json()).then(d=>{if(!d.error)browse.load();});}
// Lookup Clientes
let lkCliPage=1;const lkCliModal=new bootstrap.Modal(document.getElementById('lookupCli'));
function openLookupCli(){lkCliPage=1;document.getElementById('lkCliQ').value='';loadLkCli();lkCliModal.show();}
function loadLkCli(){fetch(`/clientes/lookup?q=${encodeURIComponent(document.getElementById('lkCliQ').value)}&page=${lkCliPage}`).then(r=>r.json()).then(d=>{document.getElementById('lkCliBody').innerHTML=d.rows.map(r=>`<tr data-id="${r.ID_CLIENTE}" data-nom="${(r.NOMBRECOMUN||'').trim()}" style="cursor:pointer"><td>${r.ID_CLIENTE}</td><td>${(r.NOMBRECOMUN||'').trim()}</td><td>${(r.RFC||'').trim()}</td></tr>`).join('');document.getElementById('lkCliInfo').textContent=`Pág ${d.page}/${d.totalPages}`;document.getElementById('lkCliPrev').disabled=d.page<=1;document.getElementById('lkCliNext').disabled=d.page>=d.totalPages;});}
document.getElementById('lkCliQ').addEventListener('input',debounce(()=>{lkCliPage=1;loadLkCli();},300));
document.getElementById('lkCliPrev').addEventListener('click',()=>{if(lkCliPage>1){lkCliPage--;loadLkCli();}});
document.getElementById('lkCliNext').addEventListener('click',()=>{lkCliPage++;loadLkCli();});
document.getElementById('lkCliBody').addEventListener('click',e=>{const row=e.target.closest('tr[data-id]');if(!row)return;document.getElementById('f_ID_CLIENTE').value=row.dataset.id;document.getElementById('f_NOMBRECOMUN').value=row.dataset.nom;lkCliModal.hide();});
</script>
