<%- include('partials/header', { titulo: 'Camiones' }) %>
<%- include('partials/sidebar') %>
<div id="page-content">
  <div class="d-flex align-items-center mb-3">
    <button class="btn btn-sm btn-outline-secondary me-3 d-md-none" id="sidebarToggle"><i class="bi bi-list fs-5"></i></button>
    <h4 class="mb-0 fw-bold flex-grow-1">Camiones</h4>
  </div>
  <div class="card border-0 shadow-sm mb-3"><div class="card-body py-2">
    <div class="row align-items-center g-2">
      <div class="col-auto"><select id="searchCol" class="form-select form-select-sm">
        <option value="MARCA">Marca</option><option value="PLACA">Placa</option><option value="ID_CAMION">ID</option><option value="TIPO">Tipo</option><option value="OPERADOR">Operador</option>
      </select></div>
      <div class="col col-md-4"><input type="text" id="searchInput" class="form-control form-select-sm" placeholder="Buscar..."></div>
      <div class="col-auto ms-auto btn-action-group">
        <button class="btn btn-sm btn-success" onclick="openAdd()"><i class="bi bi-plus-lg"></i> Agregar</button>
        <button class="btn btn-sm btn-primary" data-requires-selection disabled onclick="openEdit()"><i class="bi bi-pencil"></i> Editar</button>
        <button class="btn btn-sm btn-danger" data-requires-selection disabled onclick="confirmDelete()"><i class="bi bi-trash"></i> Eliminar</button>
      </div>
    </div>
  </div></div>
  <div class="card border-0 shadow-sm"><div class="card-body p-0">
    <div class="table-responsive"><table class="table table-hover table-sm mb-0">
      <thead class="thead-tlc"><tr>
        <th data-sort="ID_CAMION">ID <span class="sort-icon"></span></th>
        <th data-sort="MARCA">Marca <span class="sort-icon"></span></th>
        <th data-sort="PLACA">Placa <span class="sort-icon"></span></th>
        <th data-sort="TIPO">Tipo <span class="sort-icon"></span></th>
        <th data-sort="OPERADOR">Operador <span class="sort-icon"></span></th>
        <th data-sort="DESCRIPCION">Descripción <span class="sort-icon"></span></th>
      </tr></thead>
      <tbody id="tableBody"></tbody>
    </table></div>
  </div>
  <div class="card-footer bg-white d-flex align-items-center justify-content-between py-2">
    <span class="page-info" id="pageInfo"></span>
    <div id="pagination">
      <button class="btn btn-sm btn-outline-secondary" data-action="prev"><i class="bi bi-chevron-left"></i> Anterior</button>
      <button class="btn btn-sm btn-outline-secondary" data-action="next">Siguiente <i class="bi bi-chevron-right"></i></button>
    </div>
  </div></div>
</div>

<!-- Modal Formulario -->
<div class="modal fade" id="frmModal" tabindex="-1"><div class="modal-dialog modal-dialog-centered modal-xl">
  <div class="modal-content">
    <div class="modal-header"><h5 class="modal-title" id="frmTitle">Camión</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
    <div class="modal-body">
      <div id="frmError" class="alert alert-danger d-none py-2 small"></div>
      <div class="row g-3">
        <div class="col-md-2"><label class="form-label fw-semibold">ID <span class="text-danger">*</span></label><input type="text" id="f_ID_CAMION" class="form-control" maxlength="10"></div>
        <div class="col-md-2"><label class="form-label fw-semibold">Tipo</label><input type="text" id="f_TIPO" class="form-control" maxlength="20"></div>
        <div class="col-md-2"><label class="form-label fw-semibold">C. Subtipo</label><input type="text" id="f_C_SUBTIPO" class="form-control" maxlength="7"></div>
        <div class="col-md-3"><label class="form-label fw-semibold">Subtipo</label><input type="text" id="f_SUBTIPO" class="form-control" maxlength="100"></div>
        <div class="col-md-3"><label class="form-label fw-semibold">Marca</label><input type="text" id="f_MARCA" class="form-control" maxlength="20"></div>
        <div class="col-md-2"><label class="form-label fw-semibold">Placa</label><input type="text" id="f_PLACA" class="form-control" maxlength="8"></div>
        <div class="col-md-2"><label class="form-label fw-semibold">Año Modelo</label><input type="text" id="f_ANIOMODELO" class="form-control" maxlength="10"></div>
        <div class="col-md-4"><label class="form-label fw-semibold">Aseguradora</label><input type="text" id="f_NOMASEG" class="form-control" maxlength="100"></div>
        <div class="col-md-4"><label class="form-label fw-semibold">Póliza</label><input type="text" id="f_NUMPOLIZA" class="form-control" maxlength="40"></div>
        <!-- Operador Lookup -->
        <div class="col-md-5">
          <label class="form-label fw-semibold">Operador</label>
          <div class="input-group">
            <input type="hidden" id="f_ID_OPERADOR">
            <input type="text" id="f_OPERADOR" class="form-control" placeholder="Seleccionar..." readonly>
            <button class="btn btn-outline-secondary" type="button" onclick="openLookupOpe()"><i class="bi bi-search"></i></button>
          </div>
        </div>
        <div class="col-md-3"><label class="form-label fw-semibold">Descripción</label><input type="text" id="f_DESCRIPCION" class="form-control" maxlength="40"></div>
        <div class="col-md-2"><label class="form-label fw-semibold">No. Caja</label><input type="text" id="f_NOCAJA" class="form-control" maxlength="8"></div>
        <div class="col-md-2"><label class="form-label fw-semibold">No. Caja 2</label><input type="text" id="f_NOCAJA2" class="form-control" maxlength="8"></div>
        <div class="col-md-2"><label class="form-label fw-semibold">Rendimiento</label><input type="number" id="f_RENDIMIENTO" class="form-control" step="0.01"></div>
        <div class="col-md-2"><label class="form-label fw-semibold">Pago/Km</label><input type="number" id="f_PAGOKILOMETRO" class="form-control" step="0.01"></div>
        <div class="col-md-2"><label class="form-label fw-semibold">Pago/Viaje</label><input type="number" id="f_PAGOVIAJE" class="form-control" step="0.01"></div>
        <div class="col-md-2"><label class="form-label fw-semibold">Peso Bruto</label><input type="number" id="f_PESOBRUTOVEHICULAR" class="form-control" step="0.01"></div>
        <div class="col-md-2"><label class="form-label fw-semibold">Subtipo Rem.</label><input type="text" id="f_SUBTIPOREM" class="form-control" maxlength="10"></div>
        <div class="col-md-2"><label class="form-label fw-semibold">Config. Veh.</label><input type="text" id="f_CONFIGVEHICULAR" class="form-control" maxlength="10"></div>
        <div class="col-md-2"><label class="form-label fw-semibold">Perm. SCT</label><input type="text" id="f_PERMSCT" class="form-control" maxlength="10"></div>
        <div class="col-md-4"><label class="form-label fw-semibold">Núm. Permiso SCT</label><input type="text" id="f_NUMPERMISOSCT" class="form-control" maxlength="50"></div>
        <div class="col-md-2 d-flex align-items-end"><div class="form-check"><input type="checkbox" id="f_FLAGRENTA" class="form-check-input"><label class="form-check-label fw-semibold" for="f_FLAGRENTA">Renta</label></div></div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i> Cancelar</button>
      <button class="btn btn-primary" onclick="guardar()"><i class="bi bi-floppy"></i> Guardar</button>
    </div>
  </div>
</div></div>

<!-- Lookup Operadores -->
<div class="modal fade modal-lookup" id="lookupOpe" tabindex="-1"><div class="modal-dialog modal-dialog-centered modal-lg">
  <div class="modal-content">
    <div class="modal-header py-2"><h6 class="modal-title">Seleccionar Operador</h6><button class="btn-close" data-bs-dismiss="modal"></button></div>
    <div class="modal-body">
      <input type="text" id="lkOpeQ" class="form-control form-control-sm mb-2" placeholder="Buscar operador...">
      <table class="table table-hover table-sm"><thead class="table-secondary"><tr><th>ID</th><th>Nombre</th><th>RFC</th></tr></thead>
      <tbody id="lkOpeBody"></tbody></table>
      <div class="d-flex justify-content-between align-items-center">
        <span id="lkOpeInfo" class="small text-muted"></span>
        <div><button class="btn btn-sm btn-outline-secondary" id="lkOpePrev">‹</button> <button class="btn btn-sm btn-outline-secondary" id="lkOpeNext">›</button></div>
      </div>
    </div>
  </div>
</div></div>

<%- include('partials/footer') %>
<script>
const browse=initBrowse({searchInput:document.getElementById('searchInput'),searchColumn:document.getElementById('searchCol'),tableBody:document.getElementById('tableBody'),paginationEl:document.getElementById('pagination'),infoEl:document.getElementById('pageInfo'),fetchUrl:'/camiones/data'});
let _mode='add';const modal=new bootstrap.Modal(document.getElementById('frmModal'));
const txtFlds=['ID_CAMION','TIPO','C_SUBTIPO','SUBTIPO','MARCA','PLACA','ANIOMODELO','NOMASEG','NUMPOLIZA','DESCRIPCION','NOCAJA','NOCAJA2','SUBTIPOREM','CONFIGVEHICULAR','PERMSCT','NUMPERMISOSCT'];
const numFlds=['RENDIMIENTO','PAGOKILOMETRO','PAGOVIAJE','PESOBRUTOVEHICULAR'];
function clearForm(){[...txtFlds,...numFlds].forEach(f=>document.getElementById('f_'+f).value='');document.getElementById('f_OPERADOR').value='';document.getElementById('f_ID_OPERADOR').value='';document.getElementById('f_FLAGRENTA').checked=false;}
function openAdd(){_mode='add';document.getElementById('frmTitle').textContent='Nuevo Camión';clearForm();document.getElementById('f_ID_CAMION').readOnly=false;document.getElementById('frmError').classList.add('d-none');modal.show();}
function openEdit(){if(!window._selectedRow)return;_mode='edit';const r=window._selectedRow;document.getElementById('frmTitle').textContent='Editar Camión';clearForm();document.getElementById('f_ID_CAMION').value=r.ID_CAMION;document.getElementById('f_TIPO').value=r.TIPO||'';document.getElementById('f_SUBTIPO').value=r.SUBTIPO||'';document.getElementById('f_MARCA').value=r.MARCA||'';document.getElementById('f_PLACA').value=r.PLACA||'';document.getElementById('f_OPERADOR').value=r.OPERADOR||'';document.getElementById('f_ID_OPERADOR').value=r.ID_OPERADOR||'';document.getElementById('f_DESCRIPCION').value=r.DESCRIPCION||'';document.getElementById('f_FLAGRENTA').checked=r.FLAGRENTA=='1';document.getElementById('f_ID_CAMION').readOnly=true;document.getElementById('frmError').classList.add('d-none');modal.show();}
function getBody(){const b={_mode};txtFlds.forEach(f=>b[f]=document.getElementById('f_'+f).value);numFlds.forEach(f=>b[f]=document.getElementById('f_'+f).value);b.OPERADOR=document.getElementById('f_OPERADOR').value;b.ID_OPERADOR=document.getElementById('f_ID_OPERADOR').value;b.FLAGRENTA=document.getElementById('f_FLAGRENTA').checked?1:0;return b;}
function guardar(){const id=document.getElementById('f_ID_CAMION').value.trim(),errEl=document.getElementById('frmError');if(!id){errEl.textContent='ID es requerido.';errEl.classList.remove('d-none');return;}fetch('/camiones/guardar',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(getBody())}).then(r=>r.json()).then(d=>{if(d.error){errEl.textContent=d.error;errEl.classList.remove('d-none');return;}modal.hide();browse.load();});}
function confirmDelete(){if(!window._selectedRow)return;if(!confirm(`¿Eliminar camión "${window._selectedRow.ID_CAMION}"?`))return;fetch('/camiones/eliminar',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({ID_CAMION:window._selectedRow.ID_CAMION})}).then(r=>r.json()).then(d=>{if(!d.error)browse.load();});}
// Lookup operadores
let lkOpePage=1;const lkOpeModal=new bootstrap.Modal(document.getElementById('lookupOpe'));
function openLookupOpe(){lkOpePage=1;document.getElementById('lkOpeQ').value='';loadLkOpe();lkOpeModal.show();}
function loadLkOpe(){fetch(`/camiones/lookup/operadores?q=${encodeURIComponent(document.getElementById('lkOpeQ').value)}&page=${lkOpePage}`).then(r=>r.json()).then(d=>{document.getElementById('lkOpeBody').innerHTML=d.rows.map(r=>`<tr data-id="${r.ID_OPERADOR}" data-ope="${(r.OPERADOR||'').trim()}" style="cursor:pointer"><td>${r.ID_OPERADOR}</td><td>${(r.OPERADOR||'').trim()}</td><td>${(r.RFC||'').trim()}</td></tr>`).join('');document.getElementById('lkOpeInfo').textContent=`Pág ${d.page}/${d.totalPages}`;document.getElementById('lkOpePrev').disabled=d.page<=1;document.getElementById('lkOpeNext').disabled=d.page>=d.totalPages;});}
document.getElementById('lkOpeQ').addEventListener('input',debounce(()=>{lkOpePage=1;loadLkOpe();},300));
document.getElementById('lkOpePrev').addEventListener('click',()=>{if(lkOpePage>1){lkOpePage--;loadLkOpe();}});
document.getElementById('lkOpeNext').addEventListener('click',()=>{lkOpePage++;loadLkOpe();});
document.getElementById('lkOpeBody').addEventListener('click',e=>{const row=e.target.closest('tr[data-id]');if(!row)return;document.getElementById('f_ID_OPERADOR').value=row.dataset.id;document.getElementById('f_OPERADOR').value=row.dataset.ope;lkOpeModal.hide();});
</script>
