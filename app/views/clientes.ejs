<%- include('partials/header', { titulo: 'Clientes' }) %>
<%- include('partials/sidebar') %>
<div id="page-content">
  <div class="d-flex align-items-center mb-3">
    <button class="btn btn-sm btn-outline-secondary me-3 d-md-none" id="sidebarToggle"><i class="bi bi-list fs-5"></i></button>
    <h4 class="mb-0 fw-bold flex-grow-1">Clientes</h4>
  </div>
  <div class="card border-0 shadow-sm mb-3"><div class="card-body py-2">
    <div class="row align-items-center g-2">
      <div class="col-auto"><select id="searchCol" class="form-select form-select-sm">
        <option value="NOMBRECOMUN">Nombre corto</option><option value="RFC">RFC</option><option value="CIUDAD">Ciudad</option><option value="ESTADO">Estado</option><option value="TIPOCLIENTE">Tipo</option>
      </select></div>
      <div class="col col-md-4"><input type="text" id="searchInput" class="form-control form-select-sm" placeholder="Buscar..."></div>
      <div class="col-auto ms-auto btn-action-group">
        <button class="btn btn-sm btn-success" onclick="openAdd()"><i class="bi bi-plus-lg"></i> Agregar</button>
        <button class="btn btn-sm btn-primary" data-requires-selection disabled onclick="openEdit()"><i class="bi bi-pencil"></i> Editar</button>
        <button class="btn btn-sm btn-danger" data-requires-selection disabled onclick="confirmDelete()"><i class="bi bi-trash"></i> Eliminar</button>
      </div>
    </div>
  </div></div>
  <div class="card border-0 shadow-sm"><div class="card-body p-0">
    <div class="table-responsive"><table class="table table-hover table-sm mb-0">
      <thead class="thead-tlc"><tr>
        <th data-sort="ID_CLIENTE" style="width:80px">ID <span class="sort-icon"></span></th>
        <th data-sort="NOMBRECOMUN">Nombre corto <span class="sort-icon"></span></th>
        <th data-sort="RFC">RFC <span class="sort-icon"></span></th>
        <th data-sort="CIUDAD">Ciudad <span class="sort-icon"></span></th>
        <th data-sort="ESTADO">Estado <span class="sort-icon"></span></th>
        <th data-sort="TIPOCLIENTE">Tipo <span class="sort-icon"></span></th>
      </tr></thead>
      <tbody id="tableBody"></tbody>
    </table></div>
  </div>
  <div class="card-footer bg-white d-flex align-items-center justify-content-between py-2">
    <span class="page-info" id="pageInfo"></span>
    <div id="pagination">
      <button class="btn btn-sm btn-outline-secondary" data-action="prev"><i class="bi bi-chevron-left"></i> Anterior</button>
      <button class="btn btn-sm btn-outline-secondary" data-action="next">Siguiente <i class="bi bi-chevron-right"></i></button>
    </div>
  </div></div>
</div>

<!-- Modal Formulario -->
<div class="modal fade" id="frmModal" tabindex="-1"><div class="modal-dialog modal-dialog-centered modal-xl">
  <div class="modal-content">
    <div class="modal-header"><h5 class="modal-title" id="frmTitle">Cliente</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
    <div class="modal-body" style="max-height:75vh;overflow-y:auto">
      <div id="frmError" class="alert alert-danger d-none py-2 small"></div>
      <!-- Tabs -->
      <ul class="nav nav-tabs mb-3" id="cliTabs">
        <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#tabGeneral">General</a></li>
        <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tabFiscal">Fiscal / CFDI</a></li>
        <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tabConfig">Configuración</a></li>
      </ul>
      <div class="tab-content">
        <!-- General -->
        <div class="tab-pane fade show active" id="tabGeneral">
          <div class="row g-3">
            <div class="col-md-2"><label class="form-label fw-semibold">ID <span class="text-danger">*</span></label><input type="number" id="f_ID_CLIENTE" class="form-control"></div>
            <div class="col-md-3"><label class="form-label fw-semibold">Tipo</label><input type="text" id="f_TIPOCLIENTE" class="form-control" maxlength="20"></div>
            <div class="col-md-7"><label class="form-label fw-semibold">Razón social</label><input type="text" id="f_NOMBRECOM" class="form-control" maxlength="150"></div>
            <div class="col-md-5"><label class="form-label fw-semibold">Nombre corto <span class="text-danger">*</span></label><input type="text" id="f_NOMBRECOMUN" class="form-control" maxlength="80"></div>
            <div class="col-md-4"><label class="form-label fw-semibold">Calle y número</label><input type="text" id="f_CALLENUM" class="form-control" maxlength="150"></div>
            <div class="col-md-2"><label class="form-label fw-semibold">No. Ext</label><input type="text" id="f_NOEXT" class="form-control" maxlength="20"></div>
            <div class="col-md-1"><label class="form-label fw-semibold">No. Int</label><input type="text" id="f_NOINT" class="form-control" maxlength="20"></div>
            <!-- Colonia lookup -->
            <div class="col-md-4">
              <label class="form-label fw-semibold">Colonia</label>
              <div class="input-group">
                <input type="hidden" id="f_ID_COLONIA">
                <input type="text" id="f_COLONIA" class="form-control" maxlength="80" placeholder="Seleccionar..." readonly>
                <button class="btn btn-outline-secondary" type="button" onclick="openLookupColonia()"><i class="bi bi-search"></i></button>
              </div>
            </div>
            <div class="col-md-2"><label class="form-label fw-semibold">C.P.</label><input type="text" id="f_CP" class="form-control" maxlength="6" readonly></div>
            <div class="col-md-3"><label class="form-label fw-semibold">Ciudad</label><input type="text" id="f_CIUDAD" class="form-control" maxlength="80"></div>
            <div class="col-md-3"><label class="form-label fw-semibold">Municipio</label><input type="text" id="f_MUNICIPIO" class="form-control" maxlength="40"></div>
            <div class="col-md-3"><label class="form-label fw-semibold">Estado</label><input type="text" id="f_ESTADO" class="form-control" maxlength="40"></div>
            <div class="col-md-2"><label class="form-label fw-semibold">País</label><input type="text" id="f_PAIS" class="form-control" maxlength="40"></div>
            <div class="col-md-2"><label class="form-label fw-semibold">Días crédito</label><input type="number" id="f_DIASCREDITO" class="form-control"></div>
            <div class="col-md-3"><label class="form-label fw-semibold">Email facturas</label><input type="text" id="f_EMAILFACTURAS" class="form-control" maxlength="200"></div>
            <div class="col-md-3"><label class="form-label fw-semibold">Realizó</label><input type="text" id="f_REALIZO" class="form-control" maxlength="60"></div>
          </div>
        </div>
        <!-- Fiscal -->
        <div class="tab-pane fade" id="tabFiscal">
          <div class="row g-3">
            <div class="col-md-3"><label class="form-label fw-semibold">RFC</label><input type="text" id="f_RFC" class="form-control" maxlength="15"></div>
            <div class="col-md-9">
              <label class="form-label fw-semibold">Régimen Fiscal</label>
              <input type="hidden" id="f_C_REGIMENFISCAL">
              <input type="hidden" id="f_REGIMENFISCAL">
              <div class="input-group">
                <input type="text" id="f_REGIMENFISCAL_disp" class="form-control" placeholder="Seleccionar régimen fiscal..." readonly>
                <button class="btn btn-outline-secondary" type="button" onclick="openLookupSat('regimenFiscal')"><i class="bi bi-search"></i></button>
              </div>
            </div>
            <div class="col-md-5">
              <label class="form-label fw-semibold">Forma de Pago</label>
              <input type="hidden" id="f_C_FORMAPAGO">
              <input type="hidden" id="f_DESC_FORMAPAGO">
              <div class="input-group">
                <input type="text" id="f_FORMAPAGO_disp" class="form-control" placeholder="Seleccionar..." readonly>
                <button class="btn btn-outline-secondary" type="button" onclick="openLookupSat('formaPago')"><i class="bi bi-search"></i></button>
              </div>
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold">Uso CFDI</label>
              <input type="hidden" id="f_C_USOCFDI">
              <input type="hidden" id="f_DESC_USOCFDI">
              <div class="input-group">
                <input type="text" id="f_USOCFDI_disp" class="form-control" placeholder="Seleccionar..." readonly>
                <button class="btn btn-outline-secondary" type="button" onclick="openLookupSat('usoCfdi')"><i class="bi bi-search"></i></button>
              </div>
            </div>
            <div class="col-md-3"><label class="form-label fw-semibold">Clave ID Fiscal</label><input type="text" id="f_CLAVEIDFISCAL" class="form-control" maxlength="20"></div>
            <div class="col-md-9">
              <label class="form-label fw-semibold">Método de Pago</label>
              <input type="hidden" id="f_CLAVEMP">
              <input type="hidden" id="f_METODOPAGO">
              <div class="input-group">
                <input type="text" id="f_METODOPAGO_disp" class="form-control" placeholder="Seleccionar..." readonly>
                <button class="btn btn-outline-secondary" type="button" onclick="openLookupSat('metodoPago')"><i class="bi bi-search"></i></button>
              </div>
            </div>
          </div>
        </div>
        <!-- Configuración -->
        <div class="tab-pane fade" id="tabConfig">
          <div class="row g-3">
            <div class="col-md-3 d-flex align-items-center"><div class="form-check"><input type="checkbox" id="f_LOGISTICA" class="form-check-input"><label class="form-check-label fw-semibold" for="f_LOGISTICA">Logística</label></div></div>
            <div class="col-md-3 d-flex align-items-center"><div class="form-check"><input type="checkbox" id="f_FLAGEXTRANJERO" class="form-check-input"><label class="form-check-label fw-semibold" for="f_FLAGEXTRANJERO">Extranjero</label></div></div>
          </div>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i> Cancelar</button>
      <button class="btn btn-primary" onclick="guardar()"><i class="bi bi-floppy"></i> Guardar</button>
    </div>
  </div>
</div></div>

<!-- Lookup Colonia -->
<div class="modal fade modal-lookup" id="lookupColonia" tabindex="-1"><div class="modal-dialog modal-dialog-centered modal-lg">
  <div class="modal-content">
    <div class="modal-header py-2"><h6 class="modal-title">Seleccionar Colonia</h6><button class="btn-close" data-bs-dismiss="modal"></button></div>
    <div class="modal-body">
      <input type="text" id="lkColQ" class="form-control form-control-sm mb-2" placeholder="Buscar colonia o C.P...">
      <table class="table table-hover table-sm"><thead class="table-secondary"><tr><th>ID</th><th>Colonia</th><th>C.P.</th></tr></thead>
      <tbody id="lkColBody"></tbody></table>
      <div class="d-flex justify-content-between align-items-center">
        <span id="lkColInfo" class="small text-muted"></span>
        <div><button class="btn btn-sm btn-outline-secondary" id="lkColPrev">‹</button> <button class="btn btn-sm btn-outline-secondary" id="lkColNext">›</button></div>
      </div>
    </div>
  </div>
</div></div>

<!-- Lookup SAT (modal compartido para los 4 catálogos fiscales) -->
<div class="modal fade modal-lookup" id="lookupSat" tabindex="-1"><div class="modal-dialog modal-dialog-centered modal-lg">
  <div class="modal-content">
    <div class="modal-header py-2"><h6 class="modal-title" id="satLkTitle">Seleccionar</h6><button class="btn-close" data-bs-dismiss="modal"></button></div>
    <div class="modal-body">
      <input type="text" id="satLkQ" class="form-control form-control-sm mb-2" placeholder="Buscar por clave o descripción...">
      <table class="table table-hover table-sm"><thead class="table-secondary"><tr><th style="width:100px">Clave</th><th>Descripción</th></tr></thead>
      <tbody id="satLkBody"></tbody></table>
      <div class="d-flex justify-content-between align-items-center">
        <span id="satLkInfo" class="small text-muted"></span>
        <div><button class="btn btn-sm btn-outline-secondary" id="satLkPrev">‹</button> <button class="btn btn-sm btn-outline-secondary" id="satLkNext">›</button></div>
      </div>
    </div>
  </div>
</div></div>

<%- include('partials/footer') %>
<script>
const browse=initBrowse({searchInput:document.getElementById('searchInput'),searchColumn:document.getElementById('searchCol'),tableBody:document.getElementById('tableBody'),paginationEl:document.getElementById('pagination'),infoEl:document.getElementById('pageInfo'),fetchUrl:'/clientes/data'});
let _mode='add';const modal=new bootstrap.Modal(document.getElementById('frmModal'));
const txtFlds=['ID_CLIENTE','TIPOCLIENTE','NOMBRECOM','NOMBRECOMUN','CALLENUM','NOEXT','NOINT','CIUDAD','MUNICIPIO','ESTADO','PAIS','CP','EMAILFACTURAS','DIASCREDITO','REALIZO','RFC','C_REGIMENFISCAL','REGIMENFISCAL','C_FORMAPAGO','C_USOCFDI','CLAVEMP','CLAVEIDFISCAL','METODOPAGO'];
function clearForm(){txtFlds.forEach(f=>{const el=document.getElementById('f_'+f);if(el)el.value='';});document.getElementById('f_COLONIA').value='';document.getElementById('f_ID_COLONIA').value='';document.getElementById('f_LOGISTICA').checked=false;document.getElementById('f_FLAGEXTRANJERO').checked=false;['f_REGIMENFISCAL_disp','f_FORMAPAGO_disp','f_USOCFDI_disp','f_METODOPAGO_disp','f_DESC_FORMAPAGO','f_DESC_USOCFDI'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});}
function openAdd(){_mode='add';document.getElementById('frmTitle').textContent='Nuevo Cliente';clearForm();document.getElementById('f_ID_CLIENTE').readOnly=false;document.getElementById('frmError').classList.add('d-none');modal.show();}
function _satDisp(url,clave,dispId){fetch(`${url}?q=${encodeURIComponent(clave)}&page=1`).then(r=>r.json()).then(d=>{const m=d.rows.find(r=>r.clave===clave);if(m)document.getElementById(dispId).value=`${clave} - ${m.descripcion}`;});}
function openEdit(){if(!window._selectedRow)return;_mode='edit';document.getElementById('frmTitle').textContent='Editar Cliente';clearForm();const r=window._selectedRow;document.getElementById('f_ID_CLIENTE').value=r.ID_CLIENTE;document.getElementById('f_TIPOCLIENTE').value=r.TIPOCLIENTE||'';document.getElementById('f_NOMBRECOM').value=r.NOMBRECOM||'';document.getElementById('f_NOMBRECOMUN').value=r.NOMBRECOMUN||'';document.getElementById('f_RFC').value=r.RFC||'';document.getElementById('f_CIUDAD').value=r.CIUDAD||'';document.getElementById('f_ESTADO').value=r.ESTADO||'';document.getElementById('f_COLONIA').value=r.COLONIA||'';document.getElementById('f_CP').value=r.CP||'';document.getElementById('f_ID_COLONIA').value=r.ID_COLONIA||'';document.getElementById('f_DIASCREDITO').value=r.DIASCREDITO||'';document.getElementById('f_LOGISTICA').checked=r.LOGISTICA=='1';document.getElementById('f_FLAGEXTRANJERO').checked=r.FLAGEXTRANJERO=='1';const cRF=(r.C_REGIMENFISCAL||'').trim(),rF=(r.REGIMENFISCAL||'').trim();document.getElementById('f_C_REGIMENFISCAL').value=cRF;document.getElementById('f_REGIMENFISCAL').value=rF;document.getElementById('f_REGIMENFISCAL_disp').value=cRF&&rF?`${cRF} - ${rF}`:(cRF||rF);if(cRF)_satDisp('/clientes/lookup/sat/regimen-fiscal',cRF,'f_REGIMENFISCAL_disp');const cFP=(r.C_FORMAPAGO||'').trim();document.getElementById('f_C_FORMAPAGO').value=cFP;document.getElementById('f_FORMAPAGO_disp').value=cFP;if(cFP)_satDisp('/clientes/lookup/sat/forma-pago',cFP,'f_FORMAPAGO_disp');const cUC=(r.C_USOCFDI||'').trim();document.getElementById('f_C_USOCFDI').value=cUC;document.getElementById('f_USOCFDI_disp').value=cUC;if(cUC)_satDisp('/clientes/lookup/sat/uso-cfdi',cUC,'f_USOCFDI_disp');const cMP=(r.CLAVEMP||'').trim(),mP=(r.METODOPAGO||'').trim();document.getElementById('f_CLAVEMP').value=cMP;document.getElementById('f_METODOPAGO').value=mP;document.getElementById('f_METODOPAGO_disp').value=cMP&&mP?`${cMP} - ${mP}`:(cMP||mP);if(cMP)_satDisp('/clientes/lookup/sat/metodo-pago',cMP,'f_METODOPAGO_disp');document.getElementById('f_ID_CLIENTE').readOnly=true;document.getElementById('frmError').classList.add('d-none');modal.show();}
function getBody(){const b={_mode};txtFlds.forEach(f=>{const el=document.getElementById('f_'+f);if(el)b[f]=el.value;});b.COLONIA=document.getElementById('f_COLONIA').value;b.ID_COLONIA=document.getElementById('f_ID_COLONIA').value;b.LOGISTICA=document.getElementById('f_LOGISTICA').checked?1:0;b.FLAGEXTRANJERO=document.getElementById('f_FLAGEXTRANJERO').checked?1:0;return b;}
function guardar(){const id=document.getElementById('f_ID_CLIENTE').value.trim(),ncomun=document.getElementById('f_NOMBRECOMUN').value.trim(),errEl=document.getElementById('frmError');if(!id||!ncomun){errEl.textContent='ID y Nombre corto son requeridos.';errEl.classList.remove('d-none');return;}fetch('/clientes/guardar',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(getBody())}).then(r=>r.json()).then(d=>{if(d.error){errEl.textContent=d.error;errEl.classList.remove('d-none');return;}modal.hide();browse.load();});}
function confirmDelete(){if(!window._selectedRow)return;if(!confirm(`¿Eliminar cliente "${window._selectedRow.NOMBRECOMUN}"?`))return;fetch('/clientes/eliminar',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({ID_CLIENTE:window._selectedRow.ID_CLIENTE})}).then(r=>r.json()).then(d=>{if(!d.error)browse.load();});}
// Lookup Colonia
let lkColPage=1;const lkColModal=new bootstrap.Modal(document.getElementById('lookupColonia'));
function openLookupColonia(){lkColPage=1;document.getElementById('lkColQ').value='';loadLkCol();lkColModal.show();}
function loadLkCol(){fetch(`/clientes/lookup/colonias?q=${encodeURIComponent(document.getElementById('lkColQ').value)}&page=${lkColPage}`).then(r=>r.json()).then(d=>{document.getElementById('lkColBody').innerHTML=d.rows.map(r=>`<tr data-id="${r.ID_COLONIA}" data-col="${(r.COLONIA||'').trim()}" data-cp="${(r.CP||'').trim()}" style="cursor:pointer"><td>${r.ID_COLONIA}</td><td>${(r.COLONIA||'').trim()}</td><td>${(r.CP||'').trim()}</td></tr>`).join('');document.getElementById('lkColInfo').textContent=`Pág ${d.page}/${d.totalPages}`;document.getElementById('lkColPrev').disabled=d.page<=1;document.getElementById('lkColNext').disabled=d.page>=d.totalPages;});}
document.getElementById('lkColQ').addEventListener('input',debounce(()=>{lkColPage=1;loadLkCol();},300));
document.getElementById('lkColPrev').addEventListener('click',()=>{if(lkColPage>1){lkColPage--;loadLkCol();}});
document.getElementById('lkColNext').addEventListener('click',()=>{lkColPage++;loadLkCol();});
document.getElementById('lkColBody').addEventListener('click',e=>{const row=e.target.closest('tr[data-id]');if(!row)return;document.getElementById('f_ID_COLONIA').value=row.dataset.id;document.getElementById('f_COLONIA').value=row.dataset.col;document.getElementById('f_CP').value=row.dataset.cp;lkColModal.hide();});
// SAT Lookups (modal compartido para los 4 catálogos fiscales)
const _satLkCfg={
  regimenFiscal:{title:'Régimen Fiscal',url:'/clientes/lookup/sat/regimen-fiscal',onSelect:(clave,desc)=>{document.getElementById('f_C_REGIMENFISCAL').value=clave;document.getElementById('f_REGIMENFISCAL').value=desc;document.getElementById('f_REGIMENFISCAL_disp').value=`${clave} - ${desc}`;}},
  formaPago:{title:'Forma de Pago',url:'/clientes/lookup/sat/forma-pago',onSelect:(clave,desc)=>{document.getElementById('f_C_FORMAPAGO').value=clave;document.getElementById('f_DESC_FORMAPAGO').value=desc;document.getElementById('f_FORMAPAGO_disp').value=`${clave} - ${desc}`;}},
  usoCfdi:{title:'Uso CFDI',url:'/clientes/lookup/sat/uso-cfdi',onSelect:(clave,desc)=>{document.getElementById('f_C_USOCFDI').value=clave;document.getElementById('f_DESC_USOCFDI').value=desc;document.getElementById('f_USOCFDI_disp').value=`${clave} - ${desc}`;}},
  metodoPago:{title:'Método de Pago',url:'/clientes/lookup/sat/metodo-pago',onSelect:(clave,desc)=>{document.getElementById('f_CLAVEMP').value=clave;document.getElementById('f_METODOPAGO').value=desc;document.getElementById('f_METODOPAGO_disp').value=`${clave} - ${desc}`;}}
};
let _satLkModal=null,_satLkPage=1,_satLkCur=null;
function openLookupSat(type){_satLkCur=_satLkCfg[type];_satLkPage=1;document.getElementById('satLkTitle').textContent=_satLkCur.title;document.getElementById('satLkQ').value='';loadSatLk();if(!_satLkModal)_satLkModal=new bootstrap.Modal(document.getElementById('lookupSat'));_satLkModal.show();}
function loadSatLk(){fetch(`${_satLkCur.url}?q=${encodeURIComponent(document.getElementById('satLkQ').value)}&page=${_satLkPage}`).then(r=>r.json()).then(d=>{document.getElementById('satLkBody').innerHTML=d.rows.map(r=>`<tr data-clave="${r.clave}" data-desc="${(r.descripcion||'').replace(/"/g,'&quot;')}" style="cursor:pointer"><td>${r.clave}</td><td>${r.descripcion||''}</td></tr>`).join('');document.getElementById('satLkInfo').textContent=`Pág ${d.page}/${d.totalPages}`;document.getElementById('satLkPrev').disabled=d.page<=1;document.getElementById('satLkNext').disabled=d.page>=d.totalPages;});}
document.getElementById('satLkQ').addEventListener('input',debounce(()=>{_satLkPage=1;loadSatLk();},300));
document.getElementById('satLkPrev').addEventListener('click',()=>{if(_satLkPage>1){_satLkPage--;loadSatLk();}});
document.getElementById('satLkNext').addEventListener('click',()=>{_satLkPage++;loadSatLk();});
document.getElementById('satLkBody').addEventListener('click',e=>{const row=e.target.closest('tr[data-clave]');if(!row)return;_satLkCur.onSelect(row.dataset.clave,row.dataset.desc);_satLkModal.hide();});
</script>
